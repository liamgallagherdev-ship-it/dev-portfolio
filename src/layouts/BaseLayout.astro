---
import SeoHead from '../components/SeoHead.astro';

interface Props {
  title?: string;
  description?: string;
  path?: string;
  ogImage?: string;
}

const { title, description, path, ogImage } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SeoHead title={title} description={description} path={path} ogImage={ogImage} />
<link rel="preload" href="/fonts/bebas-neue-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/fonts/courier-prime-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/fonts/courier-prime-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin>
  </head>
  <body>
    <div id="theme-curtain" aria-hidden="true"></div>
    <header class="site-header">
      <nav>
        <a href="/" class="logo">LG</a>
        <ul class="nav-links">
          <li><a href="/#projects">Work</a></li>
          <li><a href="/#about">About</a></li>
          <li><a href="/#skills">Skills</a></li>
          <li><a href="/#contact">Contact</a></li>
        </ul>
        <span class="nav-status"><span class="nav-status__dot" aria-hidden="true"></span>Available</span>
      </nav>
      <script>
        const DURATION   = 680;
        const EASING     = 'cubic-bezier(0.76, 0, 0.24, 1)';
        const BG_DARK    = '#0f0f0f';
        const BG_LIGHT   = '#e5dcd3';

        const checkbox   = document.getElementById('theme-toggle');
        const curtain    = document.getElementById('theme-curtain');
        const toggleBtn  = document.getElementById('theme-toggle-btn');

        // Restore saved theme on page load (no animation)
        const savedTheme = localStorage.getItem('theme') || 'light';
        if (savedTheme === 'dark') {
          document.body.classList.add('dark-theme');
          if (checkbox) (checkbox as HTMLInputElement).checked = true;
        }

        checkbox && checkbox.addEventListener('change', function () {
          const nowDark = (this as HTMLInputElement).checked;

          // Block further clicks during animation
          if (toggleBtn) toggleBtn.style.pointerEvents = 'none';

          // Drop curtain in the incoming theme's bg colour
          if (curtain) {
            curtain.style.transition = 'none';
            curtain.style.transform  = 'scaleY(0)';
            curtain.style.background = nowDark ? BG_DARK : BG_LIGHT;
            curtain.getBoundingClientRect(); // force reflow

            curtain.style.transition = `transform ${DURATION}ms ${EASING}`;
            curtain.style.transform  = 'scaleY(1)';
          }

          setTimeout(() => {
            // Apply theme change while hidden under the curtain
            if (nowDark) {
              document.body.classList.add('dark-theme');
              localStorage.setItem('theme', 'dark');
            } else {
              document.body.classList.remove('dark-theme');
              localStorage.setItem('theme', 'light');
            }

            // Lift the curtain to reveal the new theme
            if (curtain) curtain.style.transform = 'scaleY(0)';

            setTimeout(() => {
              if (toggleBtn) toggleBtn.style.pointerEvents = '';
            }, DURATION + 60);
          }, DURATION);
        });
      </script>
    </header>
    
    <main>
      <slot />
    </main>
    
    <div class="rail" aria-hidden="true">
      <div class="rail-bar" id="railBar"></div>
      <span class="rail-hide-m">Scroll <b id="rScroll">0%</b></span>
      <span class="rail-hide-m">Viewport <b id="rView">—</b></span>
      <span>Manchester <b id="rTime">00:00:00</b></span>
      <span class="rail-hide-m">Motion <b id="rMotion">—</b></span>
      <span class="rail-live">● Live</span>
    </div>

  </body>
</html>

<style is:global>
  @font-face {
    font-family: 'Bebas Neue';
    src: url('/fonts/bebas-neue-latin-400-normal.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: block;
  }

  @font-face {
    font-family: 'Courier Prime';
    src: url('/fonts/courier-prime-latin-400-normal.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Courier Prime';
    src: url('/fonts/courier-prime-latin-700-normal.woff2') format('woff2');
    font-weight: 700;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: 'Courier Prime';
    src: url('/fonts/courier-prime-latin-400-italic.woff2') format('woff2');
    font-weight: 400;
    font-style: italic;
    font-display: swap;
  }

  @font-face {
    font-family: 'Courier Prime';
    src: url('/fonts/courier-prime-latin-700-italic.woff2') format('woff2');
    font-weight: 700;
    font-style: italic;
    font-display: swap;
  }

  :root {
    --color-bg: #080808;
;
    --color-text: #1f2937;
    --color-text-muted: #393939;
    --color-accent: #9036ad;
    --color-accent-muted: #d0b4d9
    --color-accent-hover: #501d61;
    --color-card: #e1e1e1;
    --color-border: #030303;
    --font-sans: 'Courier Prime', system-ui, sans-serif;
    
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    background-color: #080808;
    overscroll-behavior: none;
  }

  body {
    font-family: var(--font-sans);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    transition: background-color 0.3s ease, color 0.3s ease;
    overscroll-behavior: none;
  }

  

  /* Dark theme */
  body.dark-theme {
    --color-bg: #0f0f0f;
    --color-text: #e5dcd3;
    --color-text-muted: #e4e4ee;
    --color-card: #18181b;
    --color-border: #e5dcd3;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    list-style: none;
  }

  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: 64px;
    padding: 0 3rem;
    background: rgba(8,8,8,0.92);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(232,228,223,0.09);
  }

  .site-header nav {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 100%;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 64px;
    padding: 0 1.1rem;
    background: var(--hacc);
    color: #080808;
    font-family: 'Bebas Neue', 'Impact', sans-serif;
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    text-decoration: none;
    flex-shrink: 0;
    margin-left: -3rem;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  .nav-links a {
    font-family: 'Courier Prime', monospace;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(232,228,223,0.60);
    transition: color 0.2s;
  }

  .nav-links a:hover { color: #e8e4df; }

  .nav-status {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: 'Courier Prime', monospace;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--hacc);
  }

  .nav-status__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--hacc);
    animation: nav-pulse 2.4s ease-in-out infinite;
  }

  @keyframes nav-pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.25; }
  }


  main {
    min-height: 100vh;
  }


  @media (max-width: 768px) {

    .nav-links { gap: 1rem; }
    .nav-links a { font-size: 0.55rem; }
    .nav-status { display: none; }
  }

  /* ── Bottom rail ─────────────────────────────────────────────────── */
  body { padding-bottom: 46px; }

  .rail {
    position: fixed;
    left: 0; right: 0; bottom: 0;
    z-index: 60;
    height: 46px;
    background: #070907;
    color: rgba(232,228,223,0.60);
    border-top: 1px solid rgba(232,228,223,0.08);
    display: flex;
    align-items: center;
    gap: clamp(14px,4vw,48px);
    padding: 0 clamp(20px,5vw,72px);
    font-family: 'Courier Prime', monospace;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    overflow: hidden;
    white-space: nowrap;
  }

  .rail b {
    color: #e8e4df;
    font-weight: 700;
    display: inline-block;
    min-width: 4ch;
    font-variant-numeric: tabular-nums;
  }

  .rail-live {
    color: var(--hacc);
    margin-left: auto;
  }

  .rail-bar {
    position: absolute;
    left: 0; top: -1px;
    height: 2px;
    width: 0%;
    background: var(--hacc);
    transition: width 0.1s linear;
  }

  @media (max-width: 680px) { .rail-hide-m { display: none; } }

/* Toggle Button Styles */
.theme-toggle-container {
  position: relative;
  width: 74px;
  height: 36px;
}

.theme-toggle-wrapper {
  position: relative;
  height: 36px;
  background-color: #fff;
  border-radius: 100px;
}

.theme-toggle-btn {
  position: relative;
  width: 74px;
  height: 36px;
  overflow: hidden;
}

/* pill outline */
.theme-toggle-btn.btn-pill,
.theme-toggle-btn.btn-pill > .theme-toggle-bg {
  border-radius: 0px;
  outline: 2.5px solid var(--color-border);
}

.theme-toggle-checkbox {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
  z-index: 3;
}

/* background layer */
.theme-toggle-bg {
  position: absolute;
  inset: 0;
  background-color: #ebf7fc;
  transition: 0.3s ease all;
  z-index: 1;
}

/* KNOB (this is the important fix) */
.theme-toggle-knob:before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;

  width: 50%;
  height: 100%;

  background-color: teal;
  background-image: url('/images/logos/light_mode_24dp_FFFFFF_FILL0_wght400_GRAD0_opsz24.svg');
  background-size: 25px 36px;
  background-repeat: no-repeat;
  background-position: center;

  filter: grayscale(0.5);

  transform: translateX(0%);
  transition: transform 0.45s cubic-bezier(0.18, 0.89, 0.35, 1.15);
  will-change: transform;

  z-index: 2;
}

/* checked state (smooth GPU move) */
#theme-toggle-btn .theme-toggle-checkbox:checked + .theme-toggle-knob:before {
  transform: translateX(100%);
  background-image: url('/images/logos/dark_mode_24dp_FFFFFF_FILL0_wght400_GRAD0_opsz24.svg');
    background-color: var(--color-accent);
}

/* active press effect */
#theme-toggle-btn .theme-toggle-checkbox:active + .theme-toggle-knob:before {
  transform: scale(0.98);
}




body.dark-theme .theme-toggle-bg {
  background-color: #2d2d2d;
}
/* Curtain wipe overlay */
#theme-curtain {
  position: fixed;
  inset: 0;
  z-index: 99;
  transform-origin: top;
  transform: scaleY(0);
  pointer-events: none;
  will-change: transform;
}

.material-icons {
  font-variation-settings:
  'FILL' 0,
  'wght' 400,
  'GRAD' 0,
  'opsz' 24
}

</style>