---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "Frontend Developer Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bungee+Shade&family=Courier+Prime:ital,wght@0,400;0,700;1,400;1,700&family=Pixelify+Sans:wght@400..700&family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet">
  </head>
  <body>
    <header class="site-header">
      <nav>
        <a href="/" class="logo ">Liam.</a>
        <ul class="nav-links">
          <li><a href="#about">About</a></li>
          <li><a href="#skills">Skills</a></li>
          <li><a href="#projects">Projects</a></li>
          <li><a href="/css-showcase">CSS Showcase</a></li>
          <li><a href="#contact">Contact</a></li>
          <li>
            <div class="theme-toggle-container">
              <div class="theme-toggle-wrapper">
                <div class="theme-toggle-btn btn-pill" id="theme-toggle-btn">
                  <input type="checkbox" class="theme-toggle-checkbox" id="theme-toggle" />
                  <div class="theme-toggle-knob"></div>
                  <div class="theme-toggle-bg"></div>
                </div>
              </div>
            </div>
          </li>
        </ul>
      </nav>
      <script>
        // Check for saved theme preference or default to light
        const savedTheme = localStorage.getItem('theme') || 'light';
        const checkbox = document.getElementById('theme-toggle');
        
        // Apply saved theme on page load
        if (savedTheme === 'dark') {
          document.body.classList.add('dark-theme');
          checkbox.checked = true;
        }

        // Toggle theme on checkbox change
        checkbox.addEventListener('change', function() {
          if (this.checked) {
            document.body.classList.add('dark-theme');
            localStorage.setItem('theme', 'dark');
          } else {
            document.body.classList.remove('dark-theme');
            localStorage.setItem('theme', 'light');
          }
        });
      </script>
    </header>
    
    <main>
      <slot />
    </main>
    
    <footer class="site-footer">
      <p>&copy; {new Date().getFullYear()} All rights reserved.</p>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #e5dcd3;
    --color-text: #1f2937;
    --color-text-muted: #6b7280;
    --color-accent: #9036ad;
    --color-accent-muted: #d0b4d9
    --color-accent-hover: #501d61;
    --color-card: #e1e1e1;
    --color-border: #030303;
    --font-sans: 'Courier Prime', system-ui, sans-serif;
    
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  

  /* Dark theme */
  body.dark-theme {
    --color-bg: #0f0f0f;
    --color-text: #e5dcd3;
    --color-text-muted: #a1a1aa;
    --color-card: #18181b;
    --color-border: #e5dcd3;
  }

  
.pixelify {
  font-family: "Pixelify Sans", sans-serif;
  font-optical-sizing: auto;
 
}

.press-start-2p-regular {
  font-family: "Press Start 2P", system-ui;
  font-weight: 400;
  font-style: normal;
}

.vt323-regular {
  font-family: "VT323", monospace;
  font-weight: 400;
  font-style: normal;
}

.pixelify {
  font-family: "Pixelify Sans", cursive;
  font-weight: 700;
}


.courier-prime-regular {
  font-family: "Courier Prime", monospace;
  font-weight: 400;
  font-style: normal;
}

.courier-prime-bold {
  font-family: "Courier Prime", monospace;
  font-weight: 700;
  font-style: normal;
}

.courier-prime-regular-italic {
  font-family: "Courier Prime", monospace;
  font-weight: 400;
  font-style: italic;
}

.courier-prime-bold-italic {
  font-family: "Courier Prime", monospace;
  font-weight: 700;
  font-style: italic;
}

.bungee-shade-regular {
  font-family: "Bungee Shade", sans-serif;
  font-weight: 400;
  font-style: normal;
}
  a {
    color: inherit;
    text-decoration: none;
  }

  ul {
    list-style: none;
  }

  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 2rem;
background-color: var(--color-bg);
    border-bottom: 3px solid black;
  }

  .site-header nav {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-accent);
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    transition: color 0.2s ease;
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  main {
    min-height: 100vh;
  }

  .site-footer {
    padding: 2rem;
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.875rem;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .nav-links {
      display: none;
    }
  }

  /* Toggle Button Styles */
  .theme-toggle-container {
    position: relative;
    width: 74px;
    height: 36px;
  }

  .theme-toggle-wrapper {
    position: relative;
    height: 36px;
    background-color: #fff;
    border-radius: 100px;
  }

  .theme-toggle-knob,
  .theme-toggle-bg {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
  }

  .theme-toggle-btn {
    position: relative;
    width: 74px;
    height: 36px;
    overflow: hidden;
  }

  .theme-toggle-btn.btn-pill,
  .theme-toggle-btn.btn-pill > .theme-toggle-bg {

     outline: 2px solid  #9036ad;;
  
   
  }

  .theme-toggle-checkbox {
    position: relative;
    width: 100%;
    height: 100%;
    padding: 0;
    margin: 0;
    opacity: 0;
    cursor: pointer;
    z-index: 3;
  }

  .theme-toggle-knob {
    z-index: 2;
  }

  .theme-toggle-bg {
    width: 100%;
    background-color: #ebf7fc;
    transition: 0.3s ease all;
    z-index: 1;
  }

  /* Theme Toggle Button */
  #theme-toggle-btn .theme-toggle-knob:before {
    content: "";
    position: absolute;
    top: 0px;
    left: 0px;
    width: 50%;
    height: 100%;
    background-image: url('/images/logos/LightOn.svg');
    background-size: 40px 36px;
    background-repeat: no-repeat;
    background-position: center;
  filter: grayscale(0.5);
    transition: 0.3s ease all, left 0.3s cubic-bezier(0.18, 0.89, 0.35, 1.15);
  }

  #theme-toggle-btn .theme-toggle-checkbox:active + .theme-toggle-knob:before {
    width: 50%;
  
  }

  #theme-toggle-btn .theme-toggle-checkbox:checked:active + .theme-toggle-knob:before {
    margin-left: -26px;
  }

  #theme-toggle-btn .theme-toggle-checkbox:checked + .theme-toggle-knob:before {
    content: "";
    left: 50%;
    background-image: url('/images/logos/LightOff.svg');

  }

  #theme-toggle-btn .theme-toggle-checkbox:checked ~ .theme-toggle-bg {
   
  }

  /* Dark theme toggle adjustments */
  body.dark-theme .theme-toggle-wrapper {
    background-color: #e61919;
  }

  body.dark-theme .theme-toggle-bg {
    background-color: #2d2d2d;
  }

  body.dark-theme #theme-toggle-btn .theme-toggle-knob:before {
    background-color: #6366f1;
  }

  body.dark-theme #theme-toggle-btn .theme-toggle-checkbox:checked + .theme-toggle-knob:before {
    background-color: #818cf8;
  }

.material-icons {
  font-variation-settings:
  'FILL' 0,
  'wght' 400,
  'GRAD' 0,
  'opsz' 24
}

</style>