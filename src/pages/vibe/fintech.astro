<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vault — Financial Infrastructure for Builders</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <header class="header">
    <nav class="nav container">
      <a href="#" class="logo">
        <span class="logo-icon"></span>
        Vault
      </a>
      <ul class="nav-links">
        <li><a href="#features">Product</a></li>
        <li><a href="#pricing">Pricing</a></li>
        <li><a href="#">Docs</a></li>
        <li><a href="#" class="nav-login">Log in</a></li>
        <li><a href="#" class="btn btn--sm">Get started</a></li>
      </ul>
    </nav>
  </header>

  <section class="hero">
    <div class="container">
      <div class="hero-badge">Now in public beta</div>
      <h1 class="hero-title">Financial infrastructure<br /><span class="gradient-text">for the way you build.</span></h1>
      <p class="hero-sub">Vault gives your product a complete money layer — payments, accounts, and compliance — in a single API. Ship in days, not months.</p>
      <div class="hero-actions">
        <a href="#" class="btn btn--primary">Start building free</a>
        <a href="#" class="btn btn--ghost">Read the docs &rarr;</a>
      </div>
      <div class="hero-stats">
        <div class="stat">
          <span class="stat-num">99.99%</span>
          <span class="stat-label">Uptime SLA</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">180+</span>
          <span class="stat-label">Countries</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat">
          <span class="stat-num">$2B+</span>
          <span class="stat-label">Processed</span>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="dashboard">
        <div class="dash-header">
          <div class="dash-dot"></div>
          <div class="dash-dot"></div>
          <div class="dash-dot"></div>
          <span class="dash-title">vault.dashboard</span>
        </div>
        <div class="dash-body">
          <div class="dash-metric">
            <span class="dash-label">Total volume</span>
            <span class="dash-value">$1,284,920</span>
            <span class="dash-change up">+12.4%</span>
          </div>
          <div class="dash-chart">
            <div class="bar" style="height: 40%"></div>
            <div class="bar" style="height: 65%"></div>
            <div class="bar" style="height: 45%"></div>
            <div class="bar" style="height: 80%"></div>
            <div class="bar" style="height: 55%"></div>
            <div class="bar" style="height: 90%"></div>
            <div class="bar active" style="height: 75%"></div>
          </div>
          <div class="dash-rows">
            <div class="dash-row">
              <span class="dash-row-label">Stripe payout</span>
              <span class="dash-row-val green">+ $4,200.00</span>
            </div>
            <div class="dash-row">
              <span class="dash-row-label">Platform fee</span>
              <span class="dash-row-val muted">– $84.00</span>
            </div>
            <div class="dash-row">
              <span class="dash-row-label">Wire transfer</span>
              <span class="dash-row-val green">+ $18,500.00</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="features" id="features">
    <div class="container">
      <p class="section-eyebrow">Product</p>
      <h2 class="section-title">Everything you need.<br />Nothing you don't.</h2>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">⚡</div>
          <h3>Instant Payouts</h3>
          <p>Move money in real-time. Your users get paid the moment the transaction clears, not 3 business days later.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🔒</div>
          <h3>Built-in Compliance</h3>
          <p>KYC, AML, and PCI-DSS handled automatically. We keep you compliant so you can focus on building.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🌐</div>
          <h3>Global by Default</h3>
          <p>Accept payments in 135 currencies. Settle in 60+. Multi-entity support included at no extra cost.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">⚙️</div>
          <h3>One Clean API</h3>
          <p>Payments, accounts, cards, and reporting — all through a single consistent REST API with SDKs for every stack.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container">
      <h2>Start shipping financial products today.</h2>
      <p>Free to start. No monthly fees until you're ready to scale.</p>
      <a href="#" class="btn btn--primary">Get your API key</a>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <a href="#" class="logo">
        <span class="logo-icon"></span>
        Vault
      </a>
      <p>&copy; 2026 Vault Financial Inc.</p>
    </div>
  </footer>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #020817;
    --bg-2: #080f1e;
    --bg-card: #0d1829;
    --blue: #3b82f6;
    --blue-light: #60a5fa;
    --green: #22c55e;
    --text: #e2e8f0;
    --muted: #64748b;
    --border: #1e2d45;
    --font: 'Inter', system-ui, sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    font-size: 1rem;
    line-height: 1.6;
  }

  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Header */
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    background: rgba(2, 8, 23, 0.85);
    backdrop-filter: blur(16px);
  }

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 1.125rem;
    padding-bottom: 1.125rem;
  }

  .logo {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text);
  }

  .logo-icon {
    width: 20px;
    height: 20px;
    background: var(--blue);
    border-radius: 4px;
    display: inline-block;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    align-items: center;
  }

  .nav-links a {
    font-size: 0.875rem;
    color: var(--muted);
    transition: color 0.15s;
  }

  .nav-links a:hover { color: var(--text); }
  .nav-login { font-weight: 500; }

  /* Buttons */
  .btn {
    font-family: var(--font);
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.75rem 1.5rem;
    border-radius: 6px;
    border: 1px solid transparent;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    transition: all 0.15s;
  }

  .btn--sm {
    font-size: 0.8rem;
    padding: 0.5rem 1rem;
    border-radius: 5px;
    background: var(--blue);
    color: #fff;
    border-color: var(--blue);
  }

  .btn--sm:hover { background: var(--blue-light); border-color: var(--blue-light); }

  .btn--primary {
    background: var(--blue);
    color: #fff;
    border-color: var(--blue);
  }

  .btn--primary:hover { background: var(--blue-light); border-color: var(--blue-light); }

  .btn--ghost {
    background: transparent;
    color: var(--text);
    border-color: var(--border);
  }

  .btn--ghost:hover { border-color: var(--muted); }

  /* Hero */
  .hero {
    padding: 9rem 0 5rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    max-width: 1100px;
    margin: 0 auto;
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .hero-badge {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    padding: 0.3rem 0.75rem;
    border: 1px solid rgba(59, 130, 246, 0.4);
    background: rgba(59, 130, 246, 0.08);
    color: var(--blue-light);
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }

  .hero-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 1.25rem;
  }

  .gradient-text {
    background: linear-gradient(135deg, var(--blue) 0%, var(--blue-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-sub {
    font-size: 1rem;
    color: var(--muted);
    max-width: 460px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .stat { display: flex; flex-direction: column; gap: 0.2rem; }

  .stat-num {
    font-size: 1.25rem;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 0.7rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: var(--border);
  }

  /* Dashboard visual */
  .hero-visual {
    display: flex;
    justify-content: center;
  }

  .dashboard {
    width: 100%;
    max-width: 360px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 0 60px rgba(59, 130, 246, 0.08);
  }

  .dash-header {
    padding: 0.75rem 1rem;
    background: var(--bg-2);
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .dash-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--border);
  }

  .dash-title {
    font-size: 0.7rem;
    color: var(--muted);
    margin-left: 0.5rem;
    font-family: monospace;
  }

  .dash-body { padding: 1.25rem; display: flex; flex-direction: column; gap: 1.25rem; }

  .dash-metric { display: flex; flex-direction: column; gap: 0.25rem; }

  .dash-label { font-size: 0.7rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }

  .dash-value { font-size: 1.5rem; font-weight: 700; letter-spacing: -0.03em; }

  .dash-change { font-size: 0.75rem; font-weight: 600; }
  .dash-change.up { color: var(--green); }

  .dash-chart {
    display: flex;
    gap: 6px;
    align-items: flex-end;
    height: 70px;
  }

  .bar {
    flex: 1;
    background: rgba(59, 130, 246, 0.2);
    border-radius: 3px 3px 0 0;
    transition: background 0.2s;
  }

  .bar.active { background: var(--blue); }

  .dash-rows { display: flex; flex-direction: column; gap: 0.5rem; }

  .dash-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
    font-size: 0.8rem;
  }

  .dash-row:last-child { border-bottom: none; }

  .dash-row-label { color: var(--muted); }
  .dash-row-val { font-weight: 600; }
  .dash-row-val.green { color: var(--green); }
  .dash-row-val.muted { color: var(--muted); }

  /* Features */
  .features {
    padding: 7rem 0;
    border-top: 1px solid var(--border);
  }

  .section-eyebrow {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 1rem;
  }

  .section-title {
    font-size: clamp(1.75rem, 3.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 3.5rem;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  .feature-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s;
  }

  .feature-card:hover { border-color: rgba(59, 130, 246, 0.4); }

  .feature-icon { font-size: 1.5rem; }

  .feature-card h3 {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .feature-card p {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
  }

  /* CTA band */
  .cta-band {
    padding: 6rem 0;
    background: var(--bg-2);
    border-top: 1px solid var(--border);
    text-align: center;
  }

  .cta-band h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.75rem;
  }

  .cta-band p {
    color: var(--muted);
    margin-bottom: 2rem;
  }

  /* Footer */
  .footer {
    padding: 2rem 0;
    border-top: 1px solid var(--border);
  }

  .footer .container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer p {
    font-size: 0.8rem;
    color: var(--muted);
  }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; }
    .hero-visual { display: none; }
    .nav-links .btn--sm { display: none; }
  }
</style>
