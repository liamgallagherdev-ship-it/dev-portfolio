---
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Protec Boxing — Built to Fight</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Teko:wght@400;500;600;700&family=Sora:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ── NAV ──────────────────────────────────────────────────────── -->
  <header class="site-header">
    <nav class="nav">
      <a href="#" class="nav-logo">
        <img src="/images/Vibe/logo-w1.png" alt="Protec Boxing" class="nav-logo__img" />
      </a>

      <ul class="nav-links">
        <li><a href="#equipment">Equipment</a></li>
        <li><a href="#apparel">Apparel</a></li>
        <li><a href="#training">Training</a></li>
        <li><a href="#about">About</a></li>
      </ul>

      <a href="#equipment" class="nav-cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        Cart
      </a>

      <button class="nav-burger" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </nav>

    <div class="mobile-menu" aria-hidden="true">
      <ul class="mobile-menu__links">
        <li><a href="#equipment">Equipment</a></li>
        <li><a href="#apparel">Apparel</a></li>
        <li><a href="#training">Training</a></li>
        <li><a href="#about">About</a></li>
      </ul>
      <a href="#equipment" class="mobile-menu__cta">Shop Now →</a>
    </div>
  </header>

  <!-- ── HERO ─────────────────────────────────────────────────────── -->
  <section class="hero">

    <!-- main content area -->
    <div class="hero-content">
      <div class="container">

        <!-- eyebrow label -->
        <p class="hero-eyebrow" data-animate style="--delay:0.05s">
          <span class="hero-eyebrow__line"></span>
          Engineered for Champions
            <span class="hero-eyebrow__line"></span>
        </p>

        <!-- heading: "TO" row contains the info panel as a flex sibling
             so description is structurally flush against "TO"          -->
        <h1 class="hero-heading" data-animate style="--delay:0.15s">
          <span class="hero-heading__line">Built</span>
          <span class="hero-heading__to-row">
            <span class="hero-heading__line">To</span>
            <span class="hero-info">
              <span class="hero-info__description">
                Premium boxing equipment designed for elite performance.
                Tested in the ring. Trusted by champions.
              </span>
            </span>
          </span>
          <span class="hero-heading__line hero-heading__line--red"><span class="hero-word-cycle"><span class="hero-word-cycle__text">Fight</span><span class="hero-heading__dot">.</span></span></span>
        </h1>

        <a href="#equipment" class="hero-info__cta" data-animate style="--delay:0.4s">
          <span class="hero-cta__inner">
            Explore Equipment
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      </div>
    </div>

    <!-- stats strip pinned to bottom -->
    <div class="stats-bar">
      <div class="container">
        <div class="stats-bar__inner" data-animate style="--delay:0.5s">

          <div class="stat">
            <span class="stat__number">20K<sup>+</sup></span>
            <span class="stat__label">Fighters Worldwide</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat__number">30<sup>+</sup></span>
            <span class="stat__label">Countries</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat__number">100<sup>%</sup></span>
            <span class="stat__label">Commitment to the Sport</span>
          </div>

          <div class="stats-bar__est">
            <span class="stats-bar__est-label">Est.</span>
            <span class="stats-bar__est-year">1994</span>
          </div>

        </div>
      </div>
    </div>

    <!-- decorative chrome -->
    <div class="deco-corner deco-corner--top-left"></div>
    <div class="deco-corner deco-corner--bottom-left"></div>
    <span class="deco-location">Brooklyn · New York</span>
    <div class="deco-red-stripe"></div>

  </section>

  <!-- ── EQUIPMENT ────────────────────────────────────────────────── -->
  <section class="equipment" id="equipment">
    <div class="container">

      <div class="section-header" data-animate>
        <p class="section-eyebrow">
          <span class="section-eyebrow__line"></span>
          The Range
          <span class="section-eyebrow__line"></span>
        </p>
        <h2 class="section-heading">Built for Every Discipline.</h2>
      </div>

      <div class="equip-bento">
        <a href="#" class="equip-bento__card equip-bento__card--featured" data-animate>
          <span class="equip-card__cat">03</span>
          <h3 class="equip-card__title">Boxing Rings</h3>
          <p class="equip-card__desc">Custom competition rings from 6ft to full AIBA spec. Every detail engineered for the sport. Trusted by champions worldwide.</p>
          <span class="equip-card__cta">Shop Now →</span>
          <span class="equip-bento__deco">RINGS</span>
        </a>
        <a href="#" class="equip-bento__card" data-animate style="--delay:0.05s">
          <span class="equip-card__cat">01</span>
          <h3 class="equip-card__title">Boxing Gloves</h3>
          <p class="equip-card__desc">Competition-grade leather. Maximum protection and power transfer.</p>
          <span class="equip-card__cta">Shop Now →</span>
        </a>
        <a href="#" class="equip-bento__card" data-animate style="--delay:0.1s">
          <span class="equip-card__cat">02</span>
          <h3 class="equip-card__title">Punch Bags</h3>
          <p class="equip-card__desc">Heavy bags, speed bags, wall rigs. Built for punishment.</p>
          <span class="equip-card__cta">Shop Now →</span>
        </a>
        <a href="#" class="equip-bento__card" data-animate style="--delay:0.15s">
          <span class="equip-card__cat">04</span>
          <h3 class="equip-card__title">Apparel</h3>
          <p class="equip-card__desc">Shorts, vests, corner kits. Look as aggressive as you train.</p>
          <span class="equip-card__cta">Shop Now →</span>
        </a>
        <a href="#" class="equip-bento__card" data-animate style="--delay:0.2s">
          <span class="equip-card__cat">05</span>
          <h3 class="equip-card__title">MMA Equipment</h3>
          <p class="equip-card__desc">Cages, mats, and mixed-discipline gear for competition setups.</p>
          <span class="equip-card__cta">Shop Now →</span>
        </a>
        <a href="#" class="equip-bento__card" data-animate style="--delay:0.25s">
          <span class="equip-card__cat">06</span>
          <h3 class="equip-card__title">Ring Refurbishment</h3>
          <p class="equip-card__desc">Canvas, rope covers, padding. Breathe new life into your ring.</p>
          <span class="equip-card__cta">Enquire →</span>
        </a>
      </div>

    </div>
  </section>

  <!-- ── TESTIMONIALS ──────────────────────────────────────────────── -->
  <section class="testimonials" id="testimonials">
    <div class="container">

      <div class="section-header" data-animate>
        <p class="section-eyebrow">
          <span class="section-eyebrow__line"></span>
          Social Proof
          <span class="section-eyebrow__line"></span>
        </p>
        <h2 class="section-heading">Undisputed Quality.</h2>
        <p class="section-sub">Don't just take our word for it.</p>
      </div>

      <div class="testimonials-grid">

        <div class="testi-card" data-animate style="--delay:0.05s">
          <div class="testi-card__stars">★★★★★</div>
          <blockquote class="testi-card__quote">"The quality of their equipment is second to none. Our gym has been using Protec for over five years and the standard never drops."</blockquote>
          <div class="testi-card__author">
            <span class="testi-card__name">Marcus Thompson</span>
            <span class="testi-card__gym">Elite Boxing Club, London</span>
          </div>
        </div>

        <div class="testi-card" data-animate style="--delay:0.15s">
          <div class="testi-card__stars">★★★★★</div>
          <blockquote class="testi-card__quote">"We ordered a full competition ring for our gym. The build quality is exceptional and the whole team was a pleasure to deal with."</blockquote>
          <div class="testi-card__author">
            <span class="testi-card__name">Darren Walsh</span>
            <span class="testi-card__gym">Walsh Boxing Academy, Manchester</span>
          </div>
        </div>

        <div class="testi-card" data-animate style="--delay:0.25s">
          <div class="testi-card__stars">★★★★★</div>
          <blockquote class="testi-card__quote">"From gloves to full ring setups — Protec deliver every time. The gear takes everything we throw at it and keeps coming back for more."</blockquote>
          <div class="testi-card__author">
            <span class="testi-card__name">Sofia Reyes</span>
            <span class="testi-card__gym">Reyes Combat Sports, Birmingham</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── FOOTER ────────────────────────────────────────────────────── -->
  <footer class="site-footer">
    <div class="container">

      <div class="footer-inner">

        <div class="footer-brand">
          <img src="/images/Vibe/logo-w1.png" alt="Protec Boxing" class="footer-logo" />
          <p class="footer-tagline">Built to Fight.</p>
        </div>

        <nav class="footer-nav" aria-label="Products">
          <p class="footer-nav__label">Products</p>
          <ul>
            <li><a href="#equipment">Boxing Gloves</a></li>
            <li><a href="#equipment">Punch Bags</a></li>
            <li><a href="#equipment">Boxing Rings</a></li>
            <li><a href="#equipment">Apparel</a></li>
          </ul>
        </nav>

        <nav class="footer-nav" aria-label="Company">
          <p class="footer-nav__label">Company</p>
          <ul>
            <li><a href="#">About Us</a></li>
            <li><a href="#">Training</a></li>
            <li><a href="#">Blog</a></li>
            <li><a href="#">Contact</a></li>
          </ul>
        </nav>

        <div class="footer-social">
          <p class="footer-nav__label">Follow Us</p>
          <div class="footer-social__icons">
            <a href="#" class="footer-social__link" aria-label="Instagram">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/>
              </svg>
            </a>
            <a href="#" class="footer-social__link" aria-label="Facebook">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
              </svg>
            </a>
            <a href="#" class="footer-social__link" aria-label="YouTube">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/>
                <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"/>
              </svg>
            </a>
          </div>
        </div>

      </div>

      <div class="footer-legal">
        <div class="footer-legal__line"></div>
        <p class="footer-legal__text">© 2024 Protec Boxing Ltd. All rights reserved.</p>
      </div>

    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

    const burger = document.querySelector('.nav-burger');
    const mobileMenu = document.querySelector('.mobile-menu');
    burger?.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!open));
      burger.classList.toggle('is-open');
      mobileMenu.classList.toggle('is-open');
      mobileMenu.setAttribute('aria-hidden', String(open));
    });
    const cycleWords = ['Fight', 'Last', 'Work', 'Win', 'Perform'];
    let cycleIndex = 0;
    const cycleWrapper = document.querySelector('.hero-word-cycle');
    const cycleText = document.querySelector('.hero-word-cycle__text');
    if (cycleWrapper && cycleText) {
      setInterval(() => {
        cycleWrapper.classList.remove('is-entering');
        cycleWrapper.classList.add('is-exiting');
        setTimeout(() => {
          cycleIndex = (cycleIndex + 1) % cycleWords.length;
          cycleText.textContent = cycleWords[cycleIndex];
          cycleWrapper.classList.remove('is-exiting');
          cycleWrapper.classList.add('is-entering');
        }, 400);
      }, 4500);
    }

    document.querySelectorAll('.mobile-menu__links a, .mobile-menu__cta').forEach(l => {
      l.addEventListener('click', () => {
        burger.setAttribute('aria-expanded', 'false');
        burger.classList.remove('is-open');
        mobileMenu.classList.remove('is-open');
        mobileMenu.setAttribute('aria-hidden', 'true');
      });
    });
  </script>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:           #0a0a0a;
    --red:          #e3191a;
    --white:        #ffffff;
    --text-muted:   rgba(255,255,255,0.45);
    --line-dim:     rgba(255,255,255,0.12);
    --line-subtle:  rgba(255,255,255,0.08);
    --font-display: 'Teko', sans-serif;
    --font-ui:      'Teko', sans-serif;
    --font-body:    'Sora', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--white);
    font-family: var(--font-body);
    line-height: 1.6;
  }

  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2.5rem;
  }

  /* ── Site Header ─────────────────────────────────────────────────── */
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgb(0 0 0 / 12%);
    backdrop-filter: blur(16px);
border-bottom: 1px solid var(--line-subtle);
  }

  /* 3-column nav: logo | links | cart */
  .nav {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2.5rem;
    height: 60px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    justify-self: start;
  }

  .nav-logo__img {
    height: 32px;
    width: auto;
    display: block;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    justify-self: center;
  }

  .nav-links a {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--white); }

  .nav-cart {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    justify-self: end;
    transition: color 0.2s;
  }

  .nav-cart:hover { color: var(--white); }

  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px; height: 32px;
    background: none; border: none;
    cursor: pointer; padding: 4px;
    justify-self: end;
  }

  .nav-burger span {
    display: block; height: 2px;
    background: var(--white); border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .nav-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.is-open span:nth-child(2) { opacity: 0; }
  .nav-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile dropdown */
  .mobile-menu {
    background: rgb(10, 10, 10);

    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.65,0,0.076,1);
  }

  .mobile-menu.is-open { max-height: 400px; }

  .mobile-menu__links {
    padding: 1rem 2.5rem 0;
    border-top: 1px solid var(--line-subtle);
  }

  .mobile-menu__links li { border-bottom: 1px solid var(--line-subtle); }

  .mobile-menu__links a {
    display: block;
    padding: 0.875rem 0;
    font-family: var(--font-ui);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .mobile-menu__links a:hover { color: var(--white); }

  .mobile-menu__cta {
    display: inline-block;
    margin: 1.5rem 2.5rem 2rem;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--red);
  }

  /* ── Hero Section ────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    background:
      linear-gradient(100deg,
        rgba(10,10,10,1)    0%,
        rgba(10,10,10,0.92) 28%,
        rgba(10,10,10,0.55) 52%,
        rgba(10,10,10,0.15) 75%,
        rgba(10,10,10,0.05) 100%
      ),
      url('/images/Vibe/protecboxingBG.png') 68% center / cover no-repeat;
  }

  /* subtle red ambient glow on the boxer side */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 55% 70% at 72% 52%, rgba(227,25,26,0.08) 0%, transparent 65%);
    pointer-events: none;
  }

  /* vertically fills space above the stats bar */
  .hero-content {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 9rem 0 2rem;
  }

  .hero-content .container { width: 100%; }

  /* ── Eyebrow ─────────────────────────────────────────────────────── */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--red);

  }

  .hero-eyebrow__line {
    display: block;
    width: 28px; height: 1px;
    background: var(--red);
    flex-shrink: 0;
  }

  /* ── Heading + Info columns ──────────────────────────────────────── */
  .hero-heading {
    font-family: var(--font-display);
    font-size: 190px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    font-style: normal;

  
  }

  .hero-heading__line {
    display: block;
    margin-bottom: -0.30em;
    background: linear-gradient(0deg, rgb(230, 227, 227) 13%, rgba(255, 255, 255, 0.56) 80%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  .hero-heading__line:last-child { margin-bottom: 0; }
  

  /* "TO" line + info panel sit in a flex row — no offset calculation needed */
  .hero-heading__to-row {
    display: flex;
    align-items: flex-start;
    

  }

  .hero-heading__line--red {
    background: linear-gradient(
      90deg,
      rgba(227, 25, 26, 1) 50%,
      rgba(227, 25, 26, 0.33) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
        display: inline-flex;
  }

  /* ── Word cycle ─────────────────────────────────────────────────── */
  /* Gradient applied directly here so filter:blur on the same element
     works — filter on a parent would break background-clip:text        */
  .hero-word-cycle {
    display: inline-block;
    background: linear-gradient(
      90deg,
      rgba(227, 25, 26, 1) 50%,
      rgba(227, 25, 26, 0.33) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-word-cycle.is-exiting {
    animation: wordBlurOut 0.6s ease forwards;
  }

  .hero-word-cycle.is-entering {
    animation: wordBlurIn 0.6s ease forwards;
  }

  @keyframes wordBlurOut {
    0%   { opacity: 1; filter: blur(0px); }
    100% { opacity: 0; filter: blur(6px); }
  }

  @keyframes wordBlurIn {
    0%   { opacity: 0; filter: blur(6px); }
    100% { opacity: 1; filter: blur(0px); }
  }

  /* ── Info panel (description + CTA) ─────────────────────────────── */
  .hero-info {
    display: inline-flex;
    flex-direction: column;
    gap: 1.75rem;
    max-width: 260px;
    align-self: flex-start;
    /* nudge down slightly so text baseline aligns with cap-height of "TO" */
    padding-top: 0.6em;
    font-size: 1rem;
  }

  .hero-info__description {
    font-family: var(--font-body);
    font-size:17px;
    font-weight: 300;
    line-height: 1.1;
    color: var(--text-muted);
    padding-left: 1rem;
    padding-top: 1rem;
