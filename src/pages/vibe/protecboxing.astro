---
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Protec Boxing — Built to Fight</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Teko:wght@400;500;600;700&family=Sora:wght@300;400;500;600&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ── NAV ──────────────────────────────────────────────────────── -->
  <header class="site-header">
    <nav class="nav">
      <a href="#" class="nav-logo">
        <span class="nav-logo__mark">P</span>
        <span class="nav-logo__name">ROTEC</span>
      </a>

      <ul class="nav-links">
        <li><a href="#equipment">Equipment</a></li>
        <li><a href="#apparel">Apparel</a></li>
        <li><a href="#training">Training</a></li>
        <li><a href="#about">About</a></li>
      </ul>

      <a href="#equipment" class="nav-cart">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
          <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
          <line x1="3" y1="6" x2="21" y2="6"/>
          <path d="M16 10a4 4 0 0 1-8 0"/>
        </svg>
        Cart
      </a>

      <button class="nav-burger" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </nav>

    <div class="mobile-menu" aria-hidden="true">
      <ul class="mobile-menu__links">
        <li><a href="#equipment">Equipment</a></li>
        <li><a href="#apparel">Apparel</a></li>
        <li><a href="#training">Training</a></li>
        <li><a href="#about">About</a></li>
      </ul>
      <a href="#equipment" class="mobile-menu__cta">Shop Now →</a>
    </div>
  </header>

  <!-- ── HERO ─────────────────────────────────────────────────────── -->
  <section class="hero">

    <!-- main content area -->
    <div class="hero-content">
      <div class="container">

        <!-- eyebrow label -->
        <p class="hero-eyebrow" data-animate style="--delay:0.05s">
          <span class="hero-eyebrow__line"></span>
          Engineered for Champions
            <span class="hero-eyebrow__line"></span>
        </p>

        <!-- heading: "TO" row contains the info panel as a flex sibling
             so description is structurally flush against "TO"          -->
        <h1 class="hero-heading" data-animate style="--delay:0.15s">
          <span class="hero-heading__line">Built</span>
          <span class="hero-heading__to-row">
            <span class="hero-heading__line">To</span>
            <span class="hero-info">
              <span class="hero-info__description">
                Premium boxing equipment designed for elite performance.
                Tested in the ring. Trusted by champions.
              </span>
            </span>
          </span>
          <span class="hero-heading__line hero-heading__line--red"><span class="hero-word-cycle"><span class="hero-word-cycle__text">Fight</span><span class="hero-heading__dot">.</span></span></span>
        </h1>

        <a href="#equipment" class="hero-info__cta" data-animate style="--delay:0.4s">
          <span class="hero-cta__inner">
            Explore Equipment
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </span>
        </a>
      </div>
    </div>

    <!-- stats strip pinned to bottom -->
    <div class="stats-bar">
      <div class="container">
        <div class="stats-bar__inner" data-animate style="--delay:0.5s">

          <div class="stat">
            <span class="stat__number">20K<sup>+</sup></span>
            <span class="stat__label">Fighters Worldwide</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat__number">30<sup>+</sup></span>
            <span class="stat__label">Countries</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat">
            <span class="stat__number">100<sup>%</sup></span>
            <span class="stat__label">Commitment to the Sport</span>
          </div>

          <div class="stats-bar__est">
            <span class="stats-bar__est-label">Est.</span>
            <span class="stats-bar__est-year">1994</span>
          </div>

        </div>
      </div>
    </div>

    <!-- decorative chrome -->
    <div class="deco-corner deco-corner--top-left"></div>
    <div class="deco-corner deco-corner--bottom-left"></div>
    <span class="deco-location">Brooklyn · New York</span>
    <div class="deco-red-stripe"></div>

  </section>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });
    document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

    const burger = document.querySelector('.nav-burger');
    const mobileMenu = document.querySelector('.mobile-menu');
    burger?.addEventListener('click', () => {
      const open = burger.getAttribute('aria-expanded') === 'true';
      burger.setAttribute('aria-expanded', String(!open));
      burger.classList.toggle('is-open');
      mobileMenu.classList.toggle('is-open');
      mobileMenu.setAttribute('aria-hidden', String(open));
    });
    const cycleWords = ['Fight', 'Last', 'Work', 'Win', 'Perform'];
    let cycleIndex = 0;
    const cycleWrapper = document.querySelector('.hero-word-cycle');
    const cycleText = document.querySelector('.hero-word-cycle__text');
    if (cycleWrapper && cycleText) {
      setInterval(() => {
        cycleWrapper.classList.remove('is-entering');
        cycleWrapper.classList.add('is-exiting');
        setTimeout(() => {
          cycleIndex = (cycleIndex + 1) % cycleWords.length;
          cycleText.textContent = cycleWords[cycleIndex];
          cycleWrapper.classList.remove('is-exiting');
          cycleWrapper.classList.add('is-entering');
        }, 400);
      }, 4500);
    }

    document.querySelectorAll('.mobile-menu__links a, .mobile-menu__cta').forEach(l => {
      l.addEventListener('click', () => {
        burger.setAttribute('aria-expanded', 'false');
        burger.classList.remove('is-open');
        mobileMenu.classList.remove('is-open');
        mobileMenu.setAttribute('aria-hidden', 'true');
      });
    });
  </script>

</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:           #0a0a0a;
    --red:          #e3191a;
    --white:        #ffffff;
    --text-muted:   rgba(255,255,255,0.45);
    --line-dim:     rgba(255,255,255,0.12);
    --line-subtle:  rgba(255,255,255,0.08);
    --font-display: 'Teko', sans-serif;
    --font-ui:      'Teko', sans-serif;
    --font-body:    'Sora', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--white);
    font-family: var(--font-body);
    line-height: 1.6;
  }

  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }

  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2.5rem;
  }

  /* ── Site Header ─────────────────────────────────────────────────── */
  .site-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    border-top: 2px solid var(--red);
    background: rgba(10,10,10,0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--line-subtle);
  }

  /* 3-column nav: logo | links | cart */
  .nav {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2.5rem;
    height: 60px;
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 2rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: var(--font-ui);
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    justify-self: start;
  }

  .nav-logo__mark {
    width: 24px; height: 24px;
    background: var(--red);
    color: var(--white);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    justify-self: center;
  }

  .nav-links a {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--white); }

  .nav-cart {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    justify-self: end;
    transition: color 0.2s;
  }

  .nav-cart:hover { color: var(--white); }

  .nav-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 32px; height: 32px;
    background: none; border: none;
    cursor: pointer; padding: 4px;
    justify-self: end;
  }

  .nav-burger span {
    display: block; height: 2px;
    background: var(--white); border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .nav-burger.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav-burger.is-open span:nth-child(2) { opacity: 0; }
  .nav-burger.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* Mobile dropdown */
  .mobile-menu {
    background: rgba(10,10,10,0.97);
    border-bottom: 1px solid var(--line-subtle);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.65,0,0.076,1);
  }

  .mobile-menu.is-open { max-height: 400px; }

  .mobile-menu__links {
    padding: 1rem 2.5rem 0;
    border-top: 1px solid var(--line-subtle);
  }

  .mobile-menu__links li { border-bottom: 1px solid var(--line-subtle); }

  .mobile-menu__links a {
    display: block;
    padding: 0.875rem 0;
    font-family: var(--font-ui);
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    transition: color 0.2s;
  }

  .mobile-menu__links a:hover { color: var(--white); }

  .mobile-menu__cta {
    display: inline-block;
    margin: 1.5rem 2.5rem 2rem;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--red);
  }

  /* ── Hero Section ────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    background:
      linear-gradient(100deg,
        rgba(10,10,10,1)    0%,
        rgba(10,10,10,0.92) 28%,
        rgba(10,10,10,0.55) 52%,
        rgba(10,10,10,0.15) 75%,
        rgba(10,10,10,0.05) 100%
      ),
      url('/images/Vibe/protecboxingBG.png') 68% center / cover no-repeat;
  }

  /* subtle red ambient glow on the boxer side */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 55% 70% at 72% 52%, rgba(227,25,26,0.08) 0%, transparent 65%);
    pointer-events: none;
  }

  /* vertically fills space above the stats bar */
  .hero-content {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 9rem 0 2rem;
  }

  .hero-content .container { width: 100%; }

  /* ── Eyebrow ─────────────────────────────────────────────────────── */
  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    font-family: var(--font-ui);
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--red);

  }

  .hero-eyebrow__line {
    display: block;
    width: 28px; height: 1px;
    background: var(--red);
    flex-shrink: 0;
  }

  /* ── Heading + Info columns ──────────────────────────────────────── */
  .hero-heading {
    font-family: var(--font-display);
    font-size: 190px;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -0.01em;
    font-style: normal;

  
  }

  .hero-heading__line {
    display: block;
    margin-bottom: -0.30em;
    background: linear-gradient(128deg, rgb(230, 227, 227) 13%, rgba(255, 255, 255, 0.56) 80%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    color: transparent;
  }

  .hero-heading__line:last-child { margin-bottom: 0; }
  

  /* "TO" line + info panel sit in a flex row — no offset calculation needed */
  .hero-heading__to-row {
    display: flex;
    align-items: flex-start;
    

  }

  .hero-heading__line--red {
    background: linear-gradient(
      90deg,
      rgba(227, 25, 26, 1) 50%,
      rgba(227, 25, 26, 0.33) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
        display: inline-flex;
  }

  /* ── Word cycle ─────────────────────────────────────────────────── */
  /* Gradient applied directly here so filter:blur on the same element
     works — filter on a parent would break background-clip:text        */
  .hero-word-cycle {
    display: inline-block;
    background: linear-gradient(
      90deg,
      rgba(227, 25, 26, 1) 50%,
      rgba(227, 25, 26, 0.33) 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-word-cycle.is-exiting {
    animation: wordBlurOut 0.6s ease forwards;
  }

  .hero-word-cycle.is-entering {
    animation: wordBlurIn 0.6s ease forwards;
  }

  @keyframes wordBlurOut {
    0%   { opacity: 1; filter: blur(0px); }
    100% { opacity: 0; filter: blur(6px); }
  }

  @keyframes wordBlurIn {
    0%   { opacity: 0; filter: blur(6px); }
    100% { opacity: 1; filter: blur(0px); }
  }

  /* ── Info panel (description + CTA) ─────────────────────────────── */
  .hero-info {
    display: inline-flex;
    flex-direction: column;
    gap: 1.75rem;
    max-width: 260px;
    align-self: flex-start;
    /* nudge down slightly so text baseline aligns with cap-height of "TO" */
    padding-top: 0.6em;
    font-size: 1rem;
  }

  .hero-info__description {
    font-family: var(--font-body);
    font-size:17px;
    font-weight: 300;
    line-height: 1.1;
    color: var(--text-muted);
    padding-left: 1rem;
    padding-top: 1rem;
    max-width: 200px;
  }

  @property --cta-angle {
    syntax: "<angle>";
    initial-value: 0deg;
    inherits: false;
  }

  @keyframes ctaBorderSpin {
    0%   { --cta-angle: 0deg; }
    100% { --cta-angle: 360deg; }
  }

  .hero-info__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: none;
    position: relative;
    padding: 1.5px;
    text-decoration: none;
    width: fit-content;
    margin-top: 1.5rem;
    transform: translate3d(0,0,0);
    transition: transform 0.18s ease-in-out;
  }

  /* spinning conic border */
  .hero-info__cta::after,
  .hero-info__cta::before {
    content: '';
    display: block;
    position: absolute;
    inset: 0;
    background-image: conic-gradient(
      from var(--cta-angle) at 50% 50%,
      rgba(0,0,0,0)   0%,
      rgba(0,0,0,0)  33%,
      var(--red)      50%,
      rgba(0,0,0,0)  66%,
      rgba(0,0,0,0) 100%
    );
    animation: ctaBorderSpin 8s linear infinite;
  }

  /* blurred glow layer behind */
  .hero-info__cta::before {
    filter: blur(10px);
  }

  /* inner face */
  .hero-cta__inner {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.75rem;
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--red);
    z-index: 1;
    background: rgba(0,0,0,0.7);
    backdrop-filter: blur(40px);
    transition: background 0.18s ease, color 0.18s ease;
  }

  .hero-info__cta:hover .hero-cta__inner {
    background: rgba(227,25,26,0.12);
    color: #ff6055;
  }

  .hero-info__cta:active { transform: scale(0.96); }
  .hero-info__cta svg { flex-shrink: 0; }

  /* ── Stats Bar ───────────────────────────────────────────────────── */
  .stats-bar {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--line-subtle);
    background: rgba(10,10,10,0.65);
    backdrop-filter: blur(8px);
  }

  .stats-bar__inner {
    display: flex;
    align-items: center;
    padding: 1.5rem 0;
  }

  .stats-bar__est {
    margin-left: auto;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    opacity: 0.25;
  }

  .stats-bar__est-label {
    font-family: var(--font-ui);
    font-size: 0.6rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--white);
  }

  .stats-bar__est-year {
    font-family: var(--font-display);
    font-size: 1.4rem;
    line-height: 1;
    color: var(--white);
  }

  /* Individual stat */
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    padding-right: 3rem;
  }

  .stat__number {
    font-family: var(--font-display);
    font-size: 2rem;
    line-height: 1;
    color: var(--white);
  }

  .stat__number sup {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--red);
    vertical-align: super;
    line-height: 0;
  }

  .stat__label {
    font-family: var(--font-ui);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    white-space: nowrap;
  }

  .stat-divider {
    width: 1px; height: 36px;
    background: var(--line-subtle);
    margin-right: 3rem;
    flex-shrink: 0;
  }

  /* ── Decorative Chrome ───────────────────────────────────────────── */
  .deco-corner {
    position: absolute;
    width: 20px; height: 20px;
    pointer-events: none;
    z-index: 2;
  }

  .deco-corner--top-left {
    top: 72px; left: 20px;
    border-top: 1px solid var(--line-dim);
    border-left: 1px solid var(--line-dim);
  }

  .deco-corner--bottom-left {
    bottom: 72px; left: 20px;
    border-bottom: 1px solid var(--line-dim);
    border-left: 1px solid var(--line-dim);
  }

  .deco-location {
    position: absolute;
    right: 3rem; bottom: 5rem;
    font-family: var(--font-ui);
    font-size: 0.6rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.2);
    writing-mode: vertical-rl;
    pointer-events: none;
    z-index: 2;
  }

  .deco-red-stripe {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: var(--red);
    z-index: 2;
  }

  /* ── Scroll animations ───────────────────────────────────────────── */
  @media (prefers-reduced-motion: no-preference) {
    [data-animate] {
      opacity: 0;
      transform: translateY(18px);
      transition: opacity 0.6s ease, transform 0.6s ease;
      transition-delay: var(--delay, 0s);
    }
    [data-animate].is-visible { opacity: 1; transform: translateY(0); }
  }

  /* ── Responsive ──────────────────────────────────────────────────── */


  @media (max-width: 900px) {
    .nav { grid-template-columns: 1fr 1fr; }
    .nav-links, .nav-cart { display: none; }
    .nav-burger { display: flex; }
    .hero { background-position: 75% center; }
  }


  @media (max-width: 900px) {
  .hero-heading {
    font-size: 150px;
  }

    .hero-info__description {

    font-size:14px;

  }

  }


  @media (max-width: 700px) {
  


    .deco-location { display: none; }
    .hero-content { padding-top: 8rem; }
    .stat-divider { margin-right: 1.5rem; }
    .stat { padding-right: 1.5rem; }
    .stats-bar__est { display: none; }
  }

  @media (max-width: 500px) {
    .container { padding: 0 1.5rem; }
    .nav { padding: 0 1.5rem; }
    .mobile-menu__links { padding-left: 1.5rem; padding-right: 1.5rem; }
    .mobile-menu__cta { margin-left: 1.5rem; }
   
    .hero { background-position: 80% center; }
  }



    @media (max-width: 400px) {
  .hero-heading {
    font-size: 80px;
  }

    .hero-info__description {
      padding-top:0.3rem;
        padding-left:0.3rem;
    max-width: 130px;
    font-size:8.5px;

  }

  }
</style>
