  }

  .brands-label {
    flex-shrink: 0;
    padding: 0 2rem;
    color: #1a0d40;
    font-weight: 700;
    font-family: var(--font-display);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    white-space: nowrap;
    align-self: center;
    position: relative;
    z-index: 2;
  }

  .brands-overflow {
    flex: 1;
    overflow: hidden;
    position: relative;
  }

  .brands-overflow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 80px;
    background: linear-gradient(to right, var(--yellow), transparent);
    z-index: 1;
    pointer-events: none;
  }

  /* Title */
  .hero-title {
    font-family: var(--font-display);

    line-height: 0.9;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    transform: rotate(-5deg);
  }

  .line-1,
  .line-2 {
    font-size: clamp(3rem, 7vw, 5.5rem);
    color: var(--white);
font-weight: 100;
line-height: 0.85em;
  }

  .line-2 {
    display: flex;
    align-items: flex-start;
    gap: 0.1em;
  }

  .line-3 {
    font-size: clamp(3rem, 11vw, 9rem);
    color: var(--yellow);
    letter-spacing: -0.05em;
    line-height: 0.85;
  }

  .line-4 {
    font-family: var(--font-accent);
    font-size: clamp(2rem, 7vw, 5.5rem);
    color: var(--pink);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: -0.5em;
    font-weight: 100;
    font-style: italic;
    padding-bottom: 1rem;
  }

  .exclaim {
    font-size: 1.4em;
    line-height: 1;
    vertical-align: middle;
  }

  .star {
    font-size: 2.5rem;
    color: var(--yellow);
    font-style: normal;
    animation: spin 4s linear infinite;
  }

  .star--sm { font-size: 2.5rem; }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Subtext */
  .hero-sub {
    font-size: 0.95rem;
    color: var(--muted);
    max-width: 400px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  /* Button — bubbly */
  .bubbly-button {
    font-family: var(--font-display);
    font-size: 1rem;
    letter-spacing: 0.06em;
    padding: 0.9em 2.2em;
    background-color: var(--yellow);
    color: #1a0d40;
    border-radius: 4px;
    border: none;
    cursor: pointer;
    position: relative;
    isolation: isolate;
    transition: transform ease-in 0.1s, box-shadow ease-in 0.25s;
    box-shadow: 0 2px 25px rgba(255, 208, 0, 0.45);
  }

  .bubbly-button:focus { outline: 0; }

  .bubbly-button:hover {
    animation: bubbleBounce 0.6s cubic-bezier(0.36, 0.07, 0.19, 0.97) both;
  }

  @keyframes bubbleBounce {
    0%   { transform: scale(1); }
    20%  { transform: scale(1.06); }
    40%  { transform: scale(0.98); }
    60%  { transform: scale(1.03); }
    80%  { transform: scale(0.99); }
    100% { transform: scale(1); }
  }

  .bubbly-button:active {
    transform: scale(0.9);
    background-color: #e6bc00;
    box-shadow: 0 2px 25px rgba(255, 208, 0, 0.2);
  }

  .bubbly-button::before,
  .bubbly-button::after {
    position: absolute;
    content: '';
    display: block;
    width: 140%;
    height: 100%;
