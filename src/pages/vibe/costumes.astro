      <path d="M0,68 C50,55 100,76 160,65 C220,54 270,74 330,64 C390,54 440,73 510,63 C580,53 630,72 700,63 C770,54 820,72 890,64 C960,56 1010,73 1080,65 C1150,57 1210,73 1280,65 C1340,57 1400,71 1440,64 L1440,90 L0,90 Z" fill="#ffd000" opacity="0.45"/>
