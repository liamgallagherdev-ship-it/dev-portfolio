  }

  /* ── Categories bar ──────────────────────────────────────────────── */
  .categories-bar {
    background: var(--yellow);
    overflow: hidden;
  }

  /* Desktop: static centred layout, hide duplicates */
  .categories-track {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    width: 100%;
  }

  .categories-track [aria-hidden="true"] { display: none; }
  .badge-cat { display: none; }

  .category {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    font-family: var(--font-display);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #1a0d40;
    white-space: nowrap;
    border-right: 1px solid rgba(26,13,64,0.15);
