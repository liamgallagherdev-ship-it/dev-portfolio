<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:     #0d082a;
    --yellow: #ffd000;
    --pink:   #e91e8c;
    --purple: #1a0d40;
    --white:  #ffffff;
    --muted:  rgba(255,255,255,0.65);
    --font-display: 'Lilita One', cursive;
    --font-accent:  'Finger Paint', cursive;
    --font-body:    'Montserrat', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--white);
    font-family: var(--font-body);
    line-height: 1.6;
    overflow-x: hidden;
  }

  a { text-decoration: none; color: inherit; }
  ul { list-style: none; }

  /* ── Header ─────────────────────────────────────────────────────── */
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 200;
    background: rgba(13, 8, 42, 0.92);
    backdrop-filter: blur(12px);

  }

  .nav {
    max-width: 1400px;
    margin: 0 auto;
    padding: 1.75rem 2rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* Logo */
  .logo {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    flex-shrink: 0;
  }

  .logo-img {
    height: 170px;
    width: auto;
    object-fit: contain;
    position: absolute;
    top: 0;
        z-index: 100;
        transform: rotate(-5deg);
  }

  .logo-main {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.1rem;
    color: var(--yellow);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .logo-sub {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.7rem;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Nav links */
  .nav-links {
    display: flex;
    gap: 0.25rem;
    flex: 1;
    justify-content: center;
    flex-wrap: wrap;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted);
    padding: 0.35rem 0.6rem;
    white-space: nowrap;
    position: relative;
    transition: color 0.2s;
    background: none;
    border: none;
    cursor: pointer;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: 0; left: 0.6rem; right: 0.6rem;
    height: 2px;
    background: var(--yellow);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }

  .nav-link:hover { color: var(--white); }
  .nav-link:hover::after { transform: scaleX(1); }
  .nav-link.active { color: var(--yellow); }
  .nav-link.active::after { transform: scaleX(1); }

  /* Dropdown */
  .nav-more { position: relative; }

  .nav-dropdown {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    background: #1a0d40;
    border: 1px solid rgba(255,255,255,0.1);
    padding: 0.5rem 0;
    min-width: 140px;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-6px);
    transition: opacity 0.2s, transform 0.2s;
    z-index: 10;
  }

  .nav-more:hover .nav-dropdown,
  .nav-more:focus-within .nav-dropdown {
    opacity: 1;
    pointer-events: all;
    transform: translateY(0);
  }

  .dropdown-link {
    display: block;
    padding: 0.5rem 1rem;
    font-family: var(--font-body);
    font-size: 0.75rem;
    color: var(--muted);
    transition: color 0.2s, background 0.2s;
    white-space: nowrap;
  }

  .dropdown-link:hover { color: var(--white); background: rgba(255,255,255,0.05); }

  /* Contact */
  .nav-contact {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .nav-quote {
    display: flex;
    align-items: center;
    background: transparent;
    color: var(--yellow);
    font-family: var(--font-display);
    font-size: 0.8rem;
    padding: 0.3rem 0.85rem;
    border-radius: 100px;
    border: 2px solid var(--yellow);
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .nav-quote:hover {
    background: var(--yellow);
    color: #1a0d40;
  }

  .nav-email {
    font-size: 0.65rem;
    color: var(--muted);
    transition: color 0.2s;
  }

  .nav-email:hover { color: var(--white); }

  .nav-phone {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    background: var(--yellow);
    color: #1a0d40;
    font-family: var(--font-display);
  
    font-size: 0.8rem;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    transition: background 0.2s;
  }

  .nav-phone .material-symbols-outlined { font-size: 0.9rem; }
  .nav-phone:hover { background: #ffe040; }

  /* ── Hero ────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-image-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    position: absolute;
    right: 0;
    top: 0;
    height: 100%;
    width: 65%;
    object-fit: cover;
    object-position:  center;
  }

  .hero-fade {
    position: absolute;
    inset: 0;
