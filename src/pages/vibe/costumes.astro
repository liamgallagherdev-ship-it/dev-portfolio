<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:     #0d082a;
    --yellow: #ffd000;
    --pink:   #e91e8c;
    --purple: #1a0d40;
    --white:  #ffffff;
    --muted:  rgba(255,255,255,0.65);
    --font-display: 'Bungee', sans-serif;
    --font-accent:  'Finger Paint', cursive;
    --font-body:    'Montserrat', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--white);
    font-family: var(--font-body);
    line-height: 1.6;
    overflow-x: hidden;
  }

  a { text-decoration: none; color: inherit; }
  ul { list-style: none; }

  /* ── Header ─────────────────────────────────────────────────────── */
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    background: rgba(13, 8, 42, 0.88);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }

  .nav {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.75rem 2rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  /* Logo */
  .logo {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
    flex-shrink: 0;
  }

  .logo-main {
    font-family: var(--font-display);
    font-weight: 900;
    font-size: 1.1rem;
    color: var(--yellow);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .logo-sub {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.7rem;
    color: var(--white);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  /* Nav links */
  .nav-links {
    display: flex;
    gap: 0.25rem;
    flex: 1;
    justify-content: center;
    flex-wrap: wrap;
  }

  .nav-link {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--muted);
    padding: 0.35rem 0.6rem;
    border-radius: 4px;
    transition: color 0.2s, background 0.2s;
    white-space: nowrap;
  }

  .nav-link:hover,
  .nav-link.active { color: var(--white); }
  .nav-link.active { color: var(--yellow); }

  /* Contact */
  .nav-contact {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.2rem;
    flex-shrink: 0;
  }

  .nav-email {
    font-size: 0.65rem;
    color: var(--muted);
    transition: color 0.2s;
  }

  .nav-email:hover { color: var(--white); }

  .nav-phone {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    background: var(--yellow);
    color: #1a0d40;
    font-family: var(--font-display);
  
    font-size: 0.8rem;
    padding: 0.3rem 0.75rem;
    border-radius: 100px;
    transition: background 0.2s;
  }

  .nav-phone .material-symbols-outlined { font-size: 0.9rem; }
  .nav-phone:hover { background: #ffe040; }

  /* ── Hero ────────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background: var(--bg);
  }

  .hero-image-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-img {
    position: absolute;
    right: 0;
    top: 0;
    height: 100%;
    width: 65%;
    object-fit: cover;
    object-position:  center;
  }

  .hero-fade {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      var(--bg) 35%,
      rgba(13, 8, 42, 0.7) 60%,
      transparent 80%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 8rem 2rem 4rem;
  }

  .hero-content {

  }

  /* Title */
  .hero-title {
    font-family: var(--font-display);

    line-height: 0.9;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    transform: rotate(-5deg);
  }

  .line-1,
  .line-2 {
    font-size: clamp(3rem, 7vw, 5.5rem);
    color: var(--white);
    letter-spacing: -0.05em;
  }

  .line-2 {
    display: flex;
    align-items: flex-start;
    gap: 0.3em;
  }

  .line-3 {
    font-size: clamp(4.5rem, 11vw, 9rem);
    color: var(--yellow);
    letter-spacing: -0.05em;
    line-height: 0.85;
  }

  .line-4 {
    font-family: var(--font-accent);
    font-size: clamp(3rem, 7vw, 5.5rem);
    color: var(--pink);
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: -0.5em;
    font-weight: 100;
    font-style: italic;
    padding-bottom: 3rem;
  }

  .exclaim {
    font-size: 1.4em;
    line-height: 1;
    vertical-align: middle;
  }

  .star {
    font-size: 2.5rem;
    color: var(--yellow);
    font-style: normal;
    animation: spin 4s linear infinite;
  }

  .star--sm { font-size: 2.5rem; }

  @keyframes spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }

  /* Subtext */
  .hero-sub {
    font-size: 0.95rem;
    color: var(--muted);
    max-width: 400px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  /* Button */
  .btn--primary {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--yellow);
    color: #1a0d40;
    font-family: var(--font-display);
  
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.85rem 2rem;
    border-radius: 100px;
    transition: background 0.2s, transform 0.2s;
    cursor: pointer;
    border: none;
  }

  .btn--primary .material-symbols-outlined { font-size: 1.1rem; }
  .btn--primary:hover { background: #ffe040; transform: translateY(-2px); }
  .btn--primary:active { transform: translateY(0); }

  /* Badges */
  .hero-badges {
    display: flex;
    gap: 1.5rem;
    margin-top: 2.5rem; 
  wrap-flex: wrap;

  } 

  .badge {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .badge-icon {
    font-size: 2.6rem;
    color: var(--yellow);
    flex-shrink: 0;
  }

  .badge-text {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }

  .badge-text strong {
    font-family: var(--font-display);
    font-size: 0.75rem;

    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--white);
  }

  .badge-text span {
    font-size: 0.65rem;
    color: var(--muted);
  }

  /* ── Paint stroke ────────────────────────────────────────────────── */
  .paint-stroke {
    background: var(--bg);
    line-height: 0;
    margin-bottom: -1px;
    position: relative;
    z-index: 1;
  }

  .paint-stroke svg {
    display: block;
    width: 100%;
    height: 80px;
  }

  /* ── Categories bar ──────────────────────────────────────────────── */
  .categories-bar {
    background: var(--yellow);
    display: flex;
    justify-content: center;
    align-items: stretch;
    flex-wrap: wrap;
  }

  .category {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 1rem 2rem;
    font-family: var(--font-display);
    font-size: 0.8rem;

    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #1a0d40;
    border-right: 1px solid rgba(26,13,64,0.15);
    transition: background 0.2s;
    cursor: pointer;
  }

  .category:last-child { border-right: none; }
  .category:hover { background: rgba(255,255,255,0.2); }

  .category .material-symbols-outlined {
    font-size: 1.1rem;
    color: #1a0d40;
  }

  /* ── Responsive ──────────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .nav-links { display: none; }
    .hero-img { width: 80%; }
  }

  @media (max-width: 700px) {
    .nav-contact { display: none; }

    .hero-img {
      width: 100%;
      opacity: 0.35;
    }

    .hero-fade {
      background: linear-gradient(
        to right,
        var(--bg) 0%,
        rgba(13, 8, 42, 0.85) 100%
      );
    }

    .hero-content { max-width: 100%; }

    .hero-badges { gap: 1rem; }

    .badge-text span { display: none; }

    .categories-bar { justify-content: flex-start; overflow-x: auto; flex-wrap: nowrap; }
    .category { flex-shrink: 0; padding: 0.85rem 1.25rem; }
  }
</style>
