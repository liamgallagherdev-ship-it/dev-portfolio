---
import BarberTeam from '../../components/BarberTeam.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Cut — Classic Barbershop</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,300,0,0" />
</head>
<body>

  <header class="header">
    <nav class="nav">
      <a href="#" class="logo"><img src="/images/Vibe/Barber/logoPng.png" alt="The Cut" class="logo-img" /></a>
      <ul class="nav-links">
        <li><a href="#services" class="nav-cta">Book Now</a></li>
      </ul>
    </nav>
  </header>

  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow" data-animate style="--delay: 0.1s">Trumans Barbershop — Failsworth</p>
      <h1 class="hero-title" data-animate style="--delay: 0.25s">The Art</h1>
      <div class="hero-subtitle" data-animate style="--delay: 0.4s">of the Cut.</div>
      <p class="hero-sub" data-animate style="--delay: 0.55s">Old-school craft. New-school precision. Walk in looking good, leave looking great.</p>
      <div class="hero-actions" data-animate style="--delay: 0.7s">
        <a href="#services" class="btn btn--primary">
          <span class="circle" aria-hidden="true">
            <span class="material-symbols-outlined">content_cut</span>
          </span>
          <span class="button-text">View Services</span>
        </a>
      </div>
    </div>
    <div class="hero-stripe"></div>
  </section>

  <section class="services" id="services">
    <div class="container">
      <p class="section-label" data-animate>What We Do</p>
      <h2 class="section-title" data-animate style="--delay: 0.1s">Services</h2>
      <div class="services-grid">
        <a href="/vibe/barbers-book?service=The+Restyle&price=%C2%A330" class="service-card" data-animate style="--delay: 0s">
          <span class="service-num">01</span>
          <h3>The Restyle!</h3>
          <p>The full transformation. New look, new you.</p>
          <span class="service-price">£30</span>
        </a>
        <a href="/vibe/barbers-book?service=Haircut+%26+Beard+Trim&price=%C2%A321" class="service-card" data-animate style="--delay: 0.08s">
          <span class="service-num">02</span>
          <h3>Haircut &amp; Beard Trim</h3>
          <p>The complete package — sharp cut, shaped beard.</p>
          <span class="service-price">£21 <span class="price-note">+£1 skin fade</span></span>
        </a>
        <a href="/vibe/barbers-book?service=Men%27s+Cut+%26+Style&price=%C2%A318" class="service-card" data-animate style="--delay: 0.16s">
          <span class="service-num">03</span>
          <h3>Men's Cut &amp; Style</h3>
          <p>Cut, styled, and finished to walk out looking right.</p>
          <span class="service-price">£18 <span class="price-note">+£1 skin fade</span></span>
        </a>
        <a href="/vibe/barbers-book?service=Boys+Cut&price=%C2%A316" class="service-card" data-animate style="--delay: 0.24s">
          <span class="service-num">04</span>
          <h3>Boys Cut</h3>
          <p>Under 16. Clean, tidy, done properly.</p>
          <span class="service-price">£16 <span class="price-note">+£1 skin fade</span></span>
        </a>
        <a href="/vibe/barbers-book?service=OAP+Cut&price=%C2%A315" class="service-card" data-animate style="--delay: 0.32s">
          <span class="service-num">05</span>
          <h3>OAP Cut</h3>
          <p>Over 65. Classic service, respectful price.</p>
          <span class="service-price">£15</span>
        </a>
        <a href="/vibe/barbers-book?service=Clipper+Cut&price=%C2%A313" class="service-card" data-animate style="--delay: 0.4s">
          <span class="service-num">06</span>
          <h3>Clipper Cut</h3>
          <p>All over clipper — fast, clean, no fuss.</p>
          <span class="service-price">£13</span>
        </a>
        <a href="/vibe/barbers-book?service=Beard+Trim&price=%C2%A313" class="service-card" data-animate style="--delay: 0.48s">
          <span class="service-num">07</span>
          <h3>Beard Trim</h3>
          <p>Tidy up the lines. Keep the shape working for you.</p>
          <span class="service-price">£13</span>
        </a>
        <a href="/vibe/barbers-book?service=New+Client+Cut+%26+Style&price=%C2%A322" class="service-card" data-animate style="--delay: 0.56s">
          <span class="service-num">08</span>
          <h3>New Client Cut &amp; Style</h3>
          <p>First time in the chair? Extra time to talk through exactly the look you're after. No rush, no guessing.</p>
          <span class="service-price">£22</span>
        </a>
      </div>
    </div>
  </section>

  <section class="team" id="team">
    <div class="container">
      <p class="section-label" data-animate>The Crew</p>
      <h2 class="section-title" data-animate style="--delay: 0.1s">Meet the Barbers</h2>
      <BarberTeam />
    </div>
  </section>

  <section class="faqs" id="faqs">
    <div class="container">
      <p class="section-label" data-animate>Got Questions</p>
      <h2 class="section-title" data-animate style="--delay: 0.1s">FAQs</h2>
      <div class="faq-list">

        <div class="faq-item" data-animate style="--delay: 0s">
          <button class="faq-trigger" aria-expanded="false">
            <span>Do you take walk-ins?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </button>
          <div class="faq-body">
            <p>We welcome walk-ins during business hours. If you prefer to book ahead, we have availability most days. Call or use our online booking system to secure your time.</p>
          </div>
        </div>

        <div class="faq-item" data-animate style="--delay: 0.08s">
          <button class="faq-trigger" aria-expanded="false">
            <span>How long does a haircut take?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </button>
          <div class="faq-body">
            <p>A standard haircut takes about thirty minutes. Beard work and straight shaves may take longer depending on what you need. We never rush the work.</p>
          </div>
        </div>

        <div class="faq-item" data-animate style="--delay: 0.16s">
          <button class="faq-trigger" aria-expanded="false">
            <span>What's your cancellation policy?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </button>
          <div class="faq-body">
            <p>Cancel or reschedule up to twenty-four hours before your appointment with no charge. Less notice and we may charge a fee. Life happens, but we ask for courtesy.</p>
          </div>
        </div>

        <div class="faq-item" data-animate style="--delay: 0.24s">
          <button class="faq-trigger" aria-expanded="false">
            <span>What payment methods do you accept?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </button>
          <div class="faq-body">
            <p>We take cash, credit cards, and digital payments. No complications, no fuss. Pay however works best for you.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="testimonials">
    <div class="container">
      <p class="section-label" data-animate>What They Say</p>
      <h2 class="section-title" data-animate style="--delay: 0.1s">The Word</h2>
      <div class="testimonials-grid">

        <div class="testimonial-card" data-animate style="--delay: 0s">
          <div class="testimonial-stars" aria-label="5 stars">★★★★★</div>
          <p class="testimonial-quote">"Best barber I've been to in years. Knew exactly what I wanted without me having to explain it twice. Left looking sharper than I have in a long time."</p>
          <div class="testimonial-footer">
            <span class="testimonial-name">James R.</span>
            <span class="testimonial-tag">Regular since 2021</span>
          </div>
        </div>

        <div class="testimonial-card" data-animate style="--delay: 0.1s">
          <div class="testimonial-stars" aria-label="5 stars">★★★★★</div>
          <p class="testimonial-quote">"Took my lad for his first proper cut here. The barber was patient, made him feel comfortable, and the result was brilliant. We won't be going anywhere else."</p>
          <div class="testimonial-footer">
            <span class="testimonial-name">Mark T.</span>
            <span class="testimonial-tag">Walk-in</span>
          </div>
        </div>

        <div class="testimonial-card" data-animate style="--delay: 0.2s">
          <div class="testimonial-stars" aria-label="5 stars">★★★★★</div>
          <p class="testimonial-quote">"Old-school feel, proper skill. No rushing, no fuss — just a clean cut and a straight shave done right. The kind of place you tell your mates about."</p>
          <div class="testimonial-footer">
            <span class="testimonial-name">Danny K.</span>
            <span class="testimonial-tag">Beard Trim + Cut</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="info" id="visit">
    <div class="container">
      <div class="info-grid">

        <div class="info-left">
          <p class="section-label" data-animate>Find Us</p>
          <h2 class="section-title" data-animate style="--delay: 0.1s">Hours &amp; Location</h2>
          <address class="info-address" data-animate style="--delay: 0.2s">
            16 Partington Street, Failsworth, M35 9RD
          </address>
          <ul class="hours-list" data-animate style="--delay: 0.3s">
            <li class="hours-row hours-row--closed">
              <span>Monday</span><span>Closed</span>
            </li>
            <li class="hours-row">
              <span>Tuesday</span><span>09:00 – 20:00</span>
            </li>
            <li class="hours-row">
              <span>Wednesday</span><span>10:30 – 20:00</span>
            </li>
            <li class="hours-row">
              <span>Thursday</span><span>09:00 – 20:00</span>
            </li>
            <li class="hours-row">
              <span>Friday</span><span>10:30 – 20:00</span>
            </li>
            <li class="hours-row">
              <span>Saturday</span><span>08:00 – 17:00</span>
            </li>
            <li class="hours-row hours-row--closed">
              <span>Sunday</span><span>Closed</span>
            </li>
          </ul>
        </div>

        <div class="info-map" data-animate style="--delay: 0.2s">
          <iframe
            src="https://www.google.com/maps?q=Trumans+Barbershop+16+Partington+Street+Failsworth+Manchester+M35+9RD&output=embed"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Trumans Barbershop location"
          ></iframe>
        </div>

      </div>
    </div>
  </section>

  <section class="cta-band" id="book">
    <div class="container">
      <h2 data-animate>Ready for a fresh cut?</h2>
      <p data-animate style="--delay: 0.15s">No waiting. Book your chair online.</p>
      <a href="#services" class="btn btn--primary" data-animate style="--delay: 0.3s">
        <span class="circle" aria-hidden="true">
          <span class="material-symbols-outlined">content_cut</span>
        </span>
        <span class="button-text">Book Now</span>
      </a>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <div class="footer-row">
        <img src="/images/Vibe/Barber/logoPng.png" alt="The Cut" class="logo-img" />
<div class="footer-socials">
          <a href="#" aria-label="Instagram">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4.5"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="#" aria-label="Facebook">
            <svg width="30" height="30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
        </div>
        <p class="footer-copy">&copy; 2026 Trumans Barbershop</p>
      </div>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));


    document.querySelectorAll('.faq-trigger').forEach(trigger => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('.faq-item');
        const isOpen = item.classList.contains('is-open');
        document.querySelectorAll('.faq-item').forEach(i => {
          i.classList.remove('is-open');
          i.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  </script>
</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0a0a;
    --bg-2:#0a0a0a;
    --gold: #c8922a;
    --gold-light: #e8b84b;
    --cream: #f5f0e8;
    --muted: #6b6455;
    --border: #222218;
    --font-head: 'Oswald', sans-serif;
    --font-body: 'EB Garamond', serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.6;
  }

  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Header */
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(12px);
  }

  .nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 2.5rem;
    width: auto;
    object-fit: contain;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-head);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--cream); }

  .nav-cta {
    color: var(--gold) !important;
    border: 1px solid var(--gold);
    padding: 0.4rem 1rem;
    transition: background 0.2s, color 0.2s !important;
  }

  .nav-cta:hover {
    background: var(--gold) !important;
    color: var(--bg) !important;
  }

  .nav-socials {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .nav-social, .nav-account {
    display: flex;
    align-items: center;
    color: var(--muted);
    transition: color 0.2s;
  }

  .nav-social:hover, .nav-account:hover { color: var(--gold); }

  .nav-account .material-symbols-outlined { font-size: 1.3rem; }

  /* Footer */
  .footer-row {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    text-align: center;
  }

.footer-socials {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .footer-socials a {
    color: var(--muted);
    display: flex;
    transition: color 0.2s;
  }

  .footer-socials a:hover { color: var(--gold); }

  .footer-copy {
    font-family: var(--font-head);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #3a3830;
  }

  /* Mobile socials */
  .mobile-socials {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    align-items: center;
  }

  .mobile-socials a {
    color: var(--muted);
    display: flex;
    transition: color 0.2s;
  }

  .mobile-socials a:hover { color: var(--gold); }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 4rem;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(to right, rgba(10, 10, 10, 0.72) 50%, rgba(10,10,10,0.7) 100%),
      url('/images/Vibe/Barber/ChatGPT Image May 26, 2026, 11_06_22 AM.png');
    background-size: cover;
    background-position: center right;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    max-width: 640px;
    padding: 0 2rem;
  }

  .hero-eyebrow {
    font-family: var(--font-head);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
   
    color: var(--gold);
    
  }

  .hero-title {
    font-family: var(--font-head);
    font-size: 110px;
    font-weight: 700;
    line-height: 0.8;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    color: transparent;
   font-size: 90px;
    margin-top: -50px;
    margin-left: 50px;
  -webkit-text-stroke: 1px var(--gold);
  text-shadow: 0px 0px 2px black;
      line-height: 1;
       margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    color: var(--muted);
    max-width: 420px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;

  }

  .hero-stripe {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--gold);
  }

  /* Buttons */
  .btn {
    font-family: var(--font-head);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    display: inline-block;
  }

  .btn--primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: 3rem;
    overflow: hidden;
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    font-family: var(--font-head);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .btn--primary .circle {
    transition: all 0.45s cubic-bezier(0.65, 0, 0.076, 1);
    position: absolute;
    left: 0;
    top: 0;
    display: block;
    width: 3rem;
    height: 3rem;
    background: var(--gold);
  
    z-index: 0;
  }

  .btn--primary .material-symbols-outlined {
    transition: transform 0.45s cubic-bezier(0.65, 0, 0.076, 1);
    position: absolute;
    font-weight: 900;
    left: 0;
    top: 0;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: var(--bg);
  }

  .btn--primary .button-text {
    transition: color 0.45s cubic-bezier(0.65, 0, 0.076, 1);
    position: relative;
    z-index: 1;
    padding: 0 1.5rem 0 calc(3rem + 0.875rem);
    color: var(--cream);
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .btn--primary:hover .circle {
    width: 100%;
  }

  .btn--primary:hover .material-symbols-outlined {
    transform: rotate(-20deg) scale(1.1);
  }

  .btn--primary:hover .button-text {
    color: var(--bg);
  }

  .btn--ghost {
    background: transparent;
    color: var(--cream);
    border: 1px solid white;
    padding: 0px 3.5rem;
    height: 3rem;
    line-height: calc(3rem - 4px);
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .btn--ghost:hover {
    border-color: var(--gold);
    color:var(--gold);
  }

  /* Services */
  .services {
    padding: 7rem 0;
    border-top: 1px solid var(--border);
  }

  .section-label {
    font-family: var(--font-head);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
   
  
  }

  .section-title {
    font-family: var(--font-head);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    line-height:0.8;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--border);
  }

  .service-card {
    position: relative;
    padding: 2rem;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    display: grid;
    align-content: space-around;
    gap: 0.75rem;
    transition: background 0.2s;
    min-height: 300px;
    grid-template-rows: 1fr 1fr 1fr;
  }

  .service-card {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .service-card:hover {
    background: rgba(200, 146, 42, 0.07);
        border-bottom-color: var(--gold);
  }

  
  .price-note {
        position: absolute;
    font-size: 0.65rem;
    color: var(--muted);
    font-family: var(--font-head);
    letter-spacing: 0.05em;
    display: block;
    margin-top: 0.2rem;
  }

  .service-num {
       font-family: var(--font-head);
    font-size: 95px;
    font-weight: 900;
