<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Cut — Classic Barbershop</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,300,0,0" />
</head>
<body>

  <header class="header">
    <nav class="nav">
      <a href="#" class="logo"><img src="/images/Vibe/Barber/logoPng.png" alt="The Cut" class="logo-img" /></a>
      <ul class="nav-links">
        <li><a href="#services">Services</a></li>
        <li><a href="#about">About</a></li>
        <li><a href="#book" class="nav-cta">Book Now</a></li>
      </ul>
      <button class="burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </nav>
  </header>

  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <ul class="mobile-links">
      <li><a href="#services">Services</a></li>
      <li><a href="#about">About</a></li>
      <li><a href="#book" class="nav-cta">Book Now</a></li>
    </ul>
  </div>

  <section class="hero">
    <div class="hero-inner">
      <p class="hero-eyebrow" data-animate style="--delay: 0.1s">Trumans Barbershop — Failsworth</p>
      <h1 class="hero-title" data-animate style="--delay: 0.25s">The Art</h1>
      <div class="hero-subtitle" data-animate style="--delay: 0.4s">of the Cut.</div>
      <p class="hero-sub" data-animate style="--delay: 0.55s">Old-school craft. New-school precision. Walk in looking good, leave looking great.</p>
      <div class="hero-actions" data-animate style="--delay: 0.7s">
        <a href="#book" class="btn btn--ghost">Book Now</a>
        <a href="#services" class="btn btn--primary">
          <span class="circle" aria-hidden="true">
            <span class="material-symbols-outlined">content_cut</span>
          </span>
          <span class="button-text">Our Services</span>
        </a>
      </div>
    </div>
    <div class="hero-stripe"></div>
  </section>

  <section class="services" id="services">
    <div class="container">
      <p class="section-label" data-animate>What We Do</p>
      <h2 class="section-title" data-animate style="--delay: 0.1s">Services</h2>
      <div class="services-grid">
        <div class="service-card service-card--featured" data-animate style="--delay: 0s">
          <span class="service-num">01</span>
          <h3>The Restyle!</h3>
          <p>The full transformation. New look, new you.</p>
          <span class="service-price">£30</span>
        </div>
        <div class="service-card" data-animate style="--delay: 0.08s">
          <span class="service-num">02</span>
          <h3>Haircut &amp; Beard Trim</h3>
          <p>The complete package — sharp cut, shaped beard.</p>
          <span class="service-price">£21 <span class="price-note">+£1 skin fade</span></span>
        </div>
        <div class="service-card" data-animate style="--delay: 0.16s">
          <span class="service-num">03</span>
          <h3>Men's Cut &amp; Style</h3>
          <p>Cut, styled, and finished to walk out looking right.</p>
          <span class="service-price">£18 <span class="price-note">+£1 skin fade</span></span>
        </div>
        <div class="service-card" data-animate style="--delay: 0.24s">
          <span class="service-num">04</span>
          <h3>Boys Cut</h3>
          <p>Under 16. Clean, tidy, done properly.</p>
          <span class="service-price">£16 <span class="price-note">+£1 skin fade</span></span>
        </div>
        <div class="service-card" data-animate style="--delay: 0.32s">
          <span class="service-num">05</span>
          <h3>OAP Cut</h3>
          <p>Over 65. Classic service, respectful price.</p>
          <span class="service-price">£15</span>
        </div>
        <div class="service-card" data-animate style="--delay: 0.4s">
          <span class="service-num">06</span>
          <h3>Clipper Cut</h3>
          <p>All over clipper — fast, clean, no fuss.</p>
          <span class="service-price">£13</span>
        </div>
        <div class="service-card" data-animate style="--delay: 0.48s">
          <span class="service-num">07</span>
          <h3>Beard Trim</h3>
          <p>Tidy up the lines. Keep the shape working for you.</p>
          <span class="service-price">£13</span>
        </div>
      </div>
    </div>
  </section>

  <section class="faqs" id="faqs">
    <div class="container">
      <p class="section-label" data-animate>Got Questions</p>
      <h2 class="section-title" data-animate style="--delay: 0.1s">FAQs</h2>
      <div class="faq-list">

        <div class="faq-item" data-animate style="--delay: 0s">
          <button class="faq-trigger" aria-expanded="false">
            <span>Do you take walk-ins?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </button>
          <div class="faq-body">
            <p>We welcome walk-ins during business hours. If you prefer to book ahead, we have availability most days. Call or use our online booking system to secure your time.</p>
          </div>
        </div>

        <div class="faq-item" data-animate style="--delay: 0.08s">
          <button class="faq-trigger" aria-expanded="false">
            <span>How long does a haircut take?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </button>
          <div class="faq-body">
            <p>A standard haircut takes about thirty minutes. Beard work and straight shaves may take longer depending on what you need. We never rush the work.</p>
          </div>
        </div>

        <div class="faq-item" data-animate style="--delay: 0.16s">
          <button class="faq-trigger" aria-expanded="false">
            <span>What's your cancellation policy?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </button>
          <div class="faq-body">
            <p>Cancel or reschedule up to twenty-four hours before your appointment with no charge. Less notice and we may charge a fee. Life happens, but we ask for courtesy.</p>
          </div>
        </div>

        <div class="faq-item" data-animate style="--delay: 0.24s">
          <button class="faq-trigger" aria-expanded="false">
            <span>What payment methods do you accept?</span>
            <span class="faq-icon" aria-hidden="true"></span>
          </button>
          <div class="faq-body">
            <p>We take cash, credit cards, and digital payments. No complications, no fuss. Pay however works best for you.</p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="testimonials">
    <div class="container">
      <p class="section-label" data-animate>What They Say</p>
      <h2 class="section-title" data-animate style="--delay: 0.1s">The Word</h2>
      <div class="testimonials-grid">

        <div class="testimonial-card" data-animate style="--delay: 0s">
          <p class="testimonial-quote">"Best barber I've been to in years. Knew exactly what I wanted without me having to explain it twice. Left looking sharper than I have in a long time."</p>
          <div class="testimonial-footer">
            <span class="testimonial-name">James R.</span>
            <span class="testimonial-tag">Regular since 2021</span>
          </div>
        </div>

        <div class="testimonial-card" data-animate style="--delay: 0.1s">
          <p class="testimonial-quote">"Took my lad for his first proper cut here. The barber was patient, made him feel comfortable, and the result was brilliant. We won't be going anywhere else."</p>
          <div class="testimonial-footer">
            <span class="testimonial-name">Mark T.</span>
            <span class="testimonial-tag">Walk-in</span>
          </div>
        </div>

        <div class="testimonial-card" data-animate style="--delay: 0.2s">
          <p class="testimonial-quote">"Old-school feel, proper skill. No rushing, no fuss — just a clean cut and a straight shave done right. The kind of place you tell your mates about."</p>
          <div class="testimonial-footer">
            <span class="testimonial-name">Danny K.</span>
            <span class="testimonial-tag">Beard Trim + Cut</span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="cta-band" id="book">
    <div class="container">
      <h2 data-animate>Ready for a fresh cut?</h2>
      <p data-animate style="--delay: 0.15s">No waiting. Book your chair online.</p>
      <a href="#" class="btn btn--primary" data-animate style="--delay: 0.3s">
        <span class="circle" aria-hidden="true">
          <span class="material-symbols-outlined">content_cut</span>
        </span>
        <span class="button-text">Book Now</span>
      </a>
    </div>
  </section>

  <footer class="footer">
    <div class="container">
      <img src="/images/Vibe/Barber/logoPng.png" alt="The Cut" class="logo-img" />
      <p>123 Atlantic Ave, Brooklyn, NY &mdash; Mon–Sat 9am–7pm</p>
    </div>
  </footer>

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12 });

    document.querySelectorAll('[data-animate]').forEach(el => observer.observe(el));

    const burger = document.querySelector('.burger');
    const mobileMenu = document.getElementById('mobile-menu');

    burger.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.toggle('is-open');
      burger.setAttribute('aria-expanded', isOpen);
      mobileMenu.setAttribute('aria-hidden', !isOpen);
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });

    mobileMenu.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.remove('is-open');
        burger.setAttribute('aria-expanded', 'false');
        mobileMenu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      });
    });

    document.querySelectorAll('.faq-trigger').forEach(trigger => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('.faq-item');
        const isOpen = item.classList.contains('is-open');
        document.querySelectorAll('.faq-item').forEach(i => {
          i.classList.remove('is-open');
          i.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('is-open');
          trigger.setAttribute('aria-expanded', 'true');
        }
      });
    });
  </script>
</body>
</html>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0a0a;
    --bg-2:#0a0a0a;
    --gold: #c8922a;
    --gold-light: #e8b84b;
    --cream: #f5f0e8;
    --muted: #6b6455;
    --border: #222218;
    --font-head: 'Oswald', sans-serif;
    --font-body: 'EB Garamond', serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.6;
  }

  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Header */
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    background: rgba(10, 10, 10, 0.9);
    backdrop-filter: blur(12px);
  }

  .nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 2.5rem;
    width: auto;
    object-fit: contain;
  }

  .nav-links {
    display: flex;
    gap: 2.5rem;
    align-items: center;
  }

  .nav-links a {
    font-family: var(--font-head);
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--cream); }

  .nav-cta {
    color: var(--gold) !important;
    border: 1px solid var(--gold);
    padding: 0.4rem 1rem;
    transition: background 0.2s, color 0.2s !important;
  }

  .nav-cta:hover {
    background: var(--gold) !important;
    color: var(--bg) !important;
  }

  /* Hero */
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 8rem 2rem 4rem;
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(to right, rgba(10, 10, 10, 0.72) 50%, rgba(10,10,10,0.7) 100%),
      url('/images/Vibe/Barber/ChatGPT Image May 26, 2026, 11_06_22 AM.png');
    background-size: cover;
    background-position: center right;
  }

  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
    max-width: 640px;
    padding: 0 2rem;
  }

  .hero-eyebrow {
    font-family: var(--font-head);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
   
    color: var(--gold);
    
  }

  .hero-title {
    font-family: var(--font-head);
    font-size: 110px;
    font-weight: 700;
    line-height: 0.8;
    letter-spacing: -0.01em;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
  }

  .hero-subtitle {
    font-family: var(--font-body);
    font-style: italic;
    font-weight: 400;
    text-transform: none;
    color: transparent;
   font-size: 90px;
    margin-top: -50px;
    margin-left: 50px;
  -webkit-text-stroke: 1px var(--gold);
  text-shadow: 0px 0px 2px black;
      line-height: 1;
       margin-bottom: 1.5rem;
  }

  .hero-sub {
    font-size: 1.125rem;
    color: var(--muted);
    max-width: 420px;
    margin-bottom: 2.5rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;

  }

  .hero-stripe {
    position: absolute;
    right: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--gold);
  }

  /* Buttons */
  .btn {
    font-family: var(--font-head);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    display: inline-block;
  }

  .btn--primary {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: 3rem;
    overflow: hidden;
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    font-family: var(--font-head);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
  }

  .btn--primary .circle {
    transition: all 0.45s cubic-bezier(0.65, 0, 0.076, 1);
    position: absolute;
    left: 0;
    top: 0;
    display: block;
    width: 3rem;
    height: 3rem;
    background: var(--gold);
  
    z-index: 0;
  }

  .btn--primary .material-symbols-outlined {
    transition: transform 0.45s cubic-bezier(0.65, 0, 0.076, 1);
    position: absolute;
    font-weight: 900;
    left: 0;
    top: 0;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    color: var(--bg);
  }

  .btn--primary .button-text {
    transition: color 0.45s cubic-bezier(0.65, 0, 0.076, 1);
    position: relative;
    z-index: 1;
    padding: 0 1.5rem 0 calc(3rem + 0.875rem);
    color: var(--cream);
    font-weight: 700;
    line-height: 1;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .btn--primary:hover .circle {
    width: 100%;
  }

  .btn--primary:hover .material-symbols-outlined {
    transform: rotate(-20deg) scale(1.1);
  }

  .btn--primary:hover .button-text {
    color: var(--bg);
  }

  .btn--ghost {
    background: transparent;
    color: var(--cream);
    border: 1px solid white;
    padding: 0px 3.5rem;
    height: 3rem;
    line-height: calc(3rem - 4px);
    text-decoration: none;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .btn--ghost:hover {
    border-color: var(--gold);
    color:var(--gold);
  }

  /* Services */
  .services {
    padding: 7rem 0;
    border-top: 1px solid var(--border);
  }

  .section-label {
    font-family: var(--font-head);
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
   
  
  }

  .section-title {
    font-family: var(--font-head);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1.5rem;
    line-height:0.8;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border: 1px solid var(--border);
  }

  .service-card {
    padding: 2rem ;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    display: grid;
align-content: space-around;
    gap: 0.75rem;
    transition: background 0.2s;
    min-height: 300px;
     grid-template-rows: 1fr  1fr 1fr;
  }

  .service-card:hover {
    background: rgba(200, 146, 42, 0.04);
  }

  .service-card:nth-child(4n) { border-right: none; }

  .service-card--featured {
    background: rgba(200, 146, 42, 0.06);
    border-bottom-color: var(--gold);
  }

  .service-card--featured .service-card h3 {
    color: var(--gold);
  }

  .price-note {
        position: absolute;
    font-size: 0.65rem;
    color: var(--muted);
    font-family: var(--font-head);
    letter-spacing: 0.05em;
    display: block;
    margin-top: 0.2rem;
  }

  .service-num {
       font-family: var(--font-head);
    font-size: 95px;
    font-weight: 900;
    top: 0;
    right: 22px;
    /* letter-spacing: 0.15em; */
    color: #80776838;
    position: absolute;
    z-index: -1;
  }

  .service-card h3 {
    font-family: var(--font-head);
    font-size: 1.5rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.3;
  }

  .service-card p {
    font-size: 0.9rem;
    color: var(--muted);
    flex: 1;
    line-height: 1.6;
  }

  .service-price {
    font-family: var(--font-head);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: -0.02em;
  }

  /* FAQs */
  .faqs {
    padding: 7rem 0;
    border-top: 1px solid var(--border);
  }

  .faq-list {
    margin-top: 3rem;
    border-top: 1px solid var(--border);
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
  }

  .faq-trigger {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem 0;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--cream);
    font-family: var(--font-head);
    font-size: 1.1rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-align: left;
    text-transform: uppercase;
    transition: color 0.2s ease;
  }

  .faq-trigger:hover {
    color: var(--gold);
  }

  .faq-icon {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    position: relative;
    transition: transform 0.35s cubic-bezier(0.65, 0, 0.076, 1);
  }

  .faq-icon::before,
  .faq-icon::after {
    content: '';
    position: absolute;
    background: var(--gold);
    border-radius: 2px;
    transition: transform 0.35s cubic-bezier(0.65, 0, 0.076, 1), opacity 0.35s ease;
  }

  .faq-icon::before {
    width: 100%; height: 5px;
    top: 50%; left: 0;
    transform: translateY(-50%);
  }

  .faq-icon::after {
    width: 5px; height: 100%;
    left: 50%; top: 0;
    transform: translateX(-50%);
  }

  .faq-trigger[aria-expanded="true"] .faq-icon {
    transform: rotate(45deg);
  }

  .faq-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s cubic-bezier(0.65, 0, 0.076, 1);
  }

  .faq-body > p {
    overflow: hidden;
    color: var(cream);
    font-size: 1rem;
    line-height: 1.7;
    padding-bottom: 0;
    transition: padding-bottom 0.35s ease;
  }

  .faq-item.is-open .faq-body {
    grid-template-rows: 1fr;
  }

  .faq-item.is-open .faq-body > p {
    padding-bottom: 1.5rem;
  }

  /* Testimonials */
  .testimonials {
    padding: 7rem 0;
    border-top: 1px solid var(--border);
    background: var(--bg-2);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 3rem;
  }

  .testimonial-card {
    border: 1px solid var(--border);
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    position: relative;
  }

  .testimonial-card::before {
    content: '\201C';
    position: absolute;
    top: 1.25rem;
    left: 1.75rem;
    font-family: var(--font-body);
    font-size: 5rem;
    line-height: 1;
    color: var(--gold);
    opacity: 0.25;
    pointer-events: none;
  }

  .testimonial-quote {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--cream);
    opacity: 0.85;
    flex: 1;
    padding-top: 1.5rem;
  }

