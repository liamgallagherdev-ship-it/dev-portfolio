---
import BarberTeam from '../../components/BarberTeam.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Book a Chair — The Cut</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;700&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,300,0,0" />
</head>
<body>

  <header class="header">
    <nav class="nav">
      <a href="/vibe/barbers" class="logo"><img src="/images/Vibe/Barber/logoPng.png" alt="The Cut" class="logo-img" /></a>
      <a href="/vibe/barbers" class="back-link">
        <span class="material-symbols-outlined">arrow_back</span>
        Back
      </a>
    </nav>
  </header>

  <main class="booking">
    <div class="booking-inner">

      <!-- Service summary banner -->
      <div class="service-banner">
        <span class="service-banner-label">Booking for:</span>
        <span class="service-banner-name" id="serviceName">Select a service</span>
        <span class="service-banner-price" id="servicePrice"></span>
      </div>

      <!-- Progress -->
      <div class="progress">
        <div class="progress-step active" data-step="1">
          <span class="step-num">1</span>
          <span class="step-label">Barber</span>
        </div>
        <div class="progress-line"></div>
        <div class="progress-step" data-step="2">
          <span class="step-num">2</span>
          <span class="step-label">Date &amp; Time</span>
        </div>
        <div class="progress-line"></div>
        <div class="progress-step" data-step="3">
          <span class="step-num">3</span>
          <span class="step-label">Confirm</span>
        </div>
      </div>

      <!-- Step 1: Choose barber -->
      <section class="step" id="step-1">
        <h2 class="step-title">Choose your barber</h2>
        <BarberTeam selectable />
        <div class="step-actions">
          <button class="btn btn--primary" id="step1Next" disabled>
            <span class="circle" aria-hidden="true">
              <span class="material-symbols-outlined">arrow_forward</span>
            </span>
            <span class="button-text">Next: Date &amp; Time</span>
          </button>
        </div>
      </section>

      <!-- Step 2: Date & Time -->
      <section class="step hidden" id="step-2">
        <h2 class="step-title">Choose a date &amp; time</h2>
        <div class="datetime-grid">

          <div class="calendar-wrap">
            <div class="cal-header">
              <button class="cal-nav" id="calPrev" aria-label="Previous month">&#8592;</button>
              <span class="cal-month" id="calMonth"></span>
              <button class="cal-nav" id="calNext" aria-label="Next month">&#8594;</button>
            </div>
            <div class="cal-days-header">
              <span>Mo</span><span>Tu</span><span>We</span>
              <span>Th</span><span>Fr</span><span>Sa</span><span>Su</span>
            </div>
            <div class="cal-grid" id="calGrid"></div>
          </div>

          <div class="slots-wrap">
            <p class="slots-label" id="slotsLabel">Select a date to see available times</p>
            <div class="slots-grid" id="slotsGrid"></div>
          </div>

        </div>
        <div class="step-actions">
          <button class="btn btn--ghost" id="step2Back">Back</button>
          <button class="btn btn--primary" id="step2Next" disabled>
            <span class="circle" aria-hidden="true">
              <span class="material-symbols-outlined">arrow_forward</span>
            </span>
            <span class="button-text">Next: Confirm</span>
          </button>
        </div>
      </section>

      <!-- Step 3: Confirm -->
      <section class="step hidden" id="step-3">
        <h2 class="step-title">Confirm your booking</h2>
        <div class="confirm-grid">

          <div class="summary-card">
            <h3 class="summary-title">Your booking</h3>
            <ul class="summary-list">
              <li><span>Service</span><span id="sumService">—</span></li>
              <li><span>Price</span><span id="sumPrice">—</span></li>
              <li><span>Barber</span><span id="sumBarber">—</span></li>
              <li><span>Date</span><span id="sumDate">—</span></li>
              <li><span>Time</span><span id="sumTime">—</span></li>
            </ul>
          </div>

          <form class="booking-form" id="bookingForm" novalidate>
            <div class="field">
              <label for="fieldName">Full name</label>
              <input id="fieldName" type="text" placeholder="Your name" autocomplete="name" />
            </div>
            <div class="field">
              <label for="fieldEmail">Email</label>
              <input id="fieldEmail" type="email" placeholder="you@example.com" autocomplete="email" />
            </div>
            <div class="field">
              <label for="fieldPhone">Phone</label>
              <input id="fieldPhone" type="tel" placeholder="+44 7700 000000" autocomplete="tel" />
            </div>
            <div class="step-actions">
              <button type="button" class="btn btn--ghost" id="step3Back">Back</button>
              <button type="submit" class="btn btn--primary">
                <span class="circle" aria-hidden="true">
                  <span class="material-symbols-outlined">content_cut</span>
                </span>
                <span class="button-text">Confirm Booking</span>
              </button>
            </div>
          </form>

        </div>
      </section>

      <!-- Confirmation screen -->
      <section class="step hidden" id="step-done">
        <div class="done-inner">
          <span class="done-icon material-symbols-outlined">check_circle</span>
          <h2 class="done-title">You're booked in.</h2>
          <p class="done-sub">We'll send a confirmation to your email. See you at the chair.</p>
          <a href="/vibe/barbers" class="btn btn--ghost" style="margin-top:2rem;">Back to The Cut</a>
        </div>
      </section>

    </div>
  </main>

  <script>
    // ── State ──────────────────────────────────────────────────────────
    const state = {
      service: '',
      price: '',
      barber: '',
      date: null,
      time: '',
      currentMonth: new Date(),
    };

    // ── URL param: service ─────────────────────────────────────────────
    const params = new URLSearchParams(window.location.search);
    state.service = params.get('service') || '';
    state.price = params.get('price') || '';
    document.getElementById('serviceName').textContent = state.service || 'Walk-in';
    if (state.price) document.getElementById('servicePrice').textContent = state.price;

    // ── Steps ──────────────────────────────────────────────────────────
    function showStep(n) {
      document.querySelectorAll('.step').forEach(s => s.classList.add('hidden'));
      document.getElementById(`step-${n}`).classList.remove('hidden');
      document.querySelectorAll('.progress-step').forEach(s => {
        const sn = parseInt(s.dataset.step);
        s.classList.toggle('active', sn === n);
        s.classList.toggle('done', sn < n);
      });
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    // ── Step 1: Barber ─────────────────────────────────────────────────
    document.addEventListener('barber-selected', (e) => {
      state.barber = e.detail.barber;
      document.getElementById('step1Next').disabled = false;
    });

    document.getElementById('step1Next').addEventListener('click', () => {
      renderCalendar();
      showStep(2);
    });

    // ── Step 2: Calendar ───────────────────────────────────────────────
    const CLOSED_DAYS = [0, 1]; // Sun=0, Mon=1

    const DAY_SLOTS = {
      2: ['09:00','09:30','10:00','10:30','11:00','11:30','12:00','12:30','13:00','13:30','14:00','14:30','15:00','15:30','16:00','16:30','17:00','17:30','18:00','18:30','19:00','19:30'],
      3: ['10:30','11:00','11:30','12:00','12:30','13:00','13:30','14:00','14:30','15:00','15:30','16:00','16:30','17:00','17:30','18:00','18:30','19:00','19:30'],
      4: ['09:00','09:30','10:00','10:30','11:00','11:30','12:00','12:30','13:00','13:30','14:00','14:30','15:00','15:30','16:00','16:30','17:00','17:30','18:00','18:30','19:00','19:30'],
      5: ['10:30','11:00','11:30','12:00','12:30','13:00','13:30','14:00','14:30','15:00','15:30','16:00','16:30','17:00','17:30','18:00','18:30','19:00','19:30'],
      6: ['08:00','08:30','09:00','09:30','10:00','10:30','11:00','11:30','12:00','12:30','13:00','13:30','14:00','14:30','15:00','15:30','16:00','16:30'],
    };

    // Seed-based "random" booked slots for realism
    function isSlotBooked(dateStr, slot) {
      const hash = [...(dateStr + slot)].reduce((a, c) => a + c.charCodeAt(0), 0);
      return hash % 5 === 0;
    }

    function renderCalendar() {
      const d = state.currentMonth;
      const year = d.getFullYear();
      const month = d.getMonth();
      const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
      document.getElementById('calMonth').textContent = `${monthNames[month]} ${year}`;

      const grid = document.getElementById('calGrid');
      grid.innerHTML = '';

      const firstDay = new Date(year, month, 1).getDay();
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      const today = new Date(); today.setHours(0,0,0,0);

      // Offset: week starts Monday (0=Mon)
      const offset = (firstDay === 0 ? 6 : firstDay - 1);
      for (let i = 0; i < offset; i++) {
        const blank = document.createElement('div');
        blank.className = 'cal-cell cal-cell--blank';
        grid.appendChild(blank);
      }

      for (let day = 1; day <= daysInMonth; day++) {
        const date = new Date(year, month, day);
        const dow = date.getDay();
        const isPast = date < today;
        const isClosed = CLOSED_DAYS.includes(dow);
        const cell = document.createElement('button');
        cell.className = 'cal-cell';
        cell.textContent = day;
        cell.disabled = isPast || isClosed;
        if (isClosed) cell.classList.add('cal-cell--closed');
        if (!isPast && !isClosed) cell.classList.add('cal-cell--open');

        if (state.date && date.toDateString() === state.date.toDateString()) {
          cell.classList.add('selected');
        }

        cell.addEventListener('click', () => {
          document.querySelectorAll('.cal-cell').forEach(c => c.classList.remove('selected'));
          cell.classList.add('selected');
          state.date = date;
          state.time = '';
          document.getElementById('step2Next').disabled = true;
          renderSlots(date);
        });

        grid.appendChild(cell);
      }
    }

    function renderSlots(date) {
      const dow = date.getDay();
      const slots = DAY_SLOTS[dow] || [];
      const grid = document.getElementById('slotsGrid');
      const label = document.getElementById('slotsLabel');
      const dateStr = date.toISOString().split('T')[0];

      const dayNames = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
      label.textContent = `Available times — ${dayNames[dow]} ${date.getDate()}`;

      grid.innerHTML = '';
      slots.forEach(slot => {
        const booked = isSlotBooked(dateStr, slot);
        const btn = document.createElement('button');
        btn.className = 'slot' + (booked ? ' slot--booked' : '');
        btn.textContent = slot;
        btn.disabled = booked;
        btn.addEventListener('click', () => {
          document.querySelectorAll('.slot').forEach(s => s.classList.remove('selected'));
          btn.classList.add('selected');
          state.time = slot;
          document.getElementById('step2Next').disabled = false;
        });
        grid.appendChild(btn);
      });
    }

    document.getElementById('calPrev').addEventListener('click', () => {
      state.currentMonth.setMonth(state.currentMonth.getMonth() - 1);
      renderCalendar();
    });

    document.getElementById('calNext').addEventListener('click', () => {
      state.currentMonth.setMonth(state.currentMonth.getMonth() + 1);
      renderCalendar();
    });

    document.getElementById('step2Back').addEventListener('click', () => showStep(1));

    document.getElementById('step2Next').addEventListener('click', () => {
      const opts = { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' };
      document.getElementById('sumService').textContent = state.service || 'Walk-in';
      document.getElementById('sumPrice').textContent = state.price || '—';
      document.getElementById('sumBarber').textContent = state.barber;
      document.getElementById('sumDate').textContent = state.date.toLocaleDateString('en-GB', opts);
      document.getElementById('sumTime').textContent = state.time;
      showStep(3);
    });

    // ── Step 3: Confirm ────────────────────────────────────────────────
    document.getElementById('step3Back').addEventListener('click', () => showStep(2));

    document.getElementById('bookingForm').addEventListener('submit', (e) => {
      e.preventDefault();
      showStep('done');
    });
  </script>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #0a0a0a;
    --bg-2: #111110;
    --gold: #c8922a;
    --gold-light: #e8b84b;
    --cream: #f5f0e8;
    --muted: #6b6455;
    --border: #222218;
    --font-head: 'Oswald', sans-serif;
    --font-body: 'EB Garamond', serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.6;
    min-height: 100vh;
  }

  a { color: inherit; text-decoration: none; }
  ul { list-style: none; }
  button { cursor: pointer; }
  input, button { font-family: inherit; }

  .hidden { display: none !important; }

  /* Header */
  .header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    border-bottom: 1px solid var(--border);
    background: rgba(10,10,10,0.92);
    backdrop-filter: blur(12px);
  }

  .nav {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .logo { display: flex; align-items: center; }

  .logo-img {
    height: 2.25rem;
    width: auto;
    object-fit: contain;
  }

  .back-link {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    font-family: var(--font-head);
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
  }

  .back-link .material-symbols-outlined { font-size: 1rem; }
  .back-link:hover { color: var(--cream); }

  /* Booking layout */
  .booking {
    padding: 8rem 2rem 6rem;
  }

  .booking-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  /* Service banner */
  .service-banner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1.25rem;
    border: 1px solid var(--border);
    background: var(--bg-2);
    margin-bottom: 2.5rem;
    font-family: var(--font-head);
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .service-banner-label { color: var(--muted); }
  .service-banner-name { color: var(--gold); font-weight: 700; }
  .service-banner-price {
    margin-left: auto;
    color: var(--cream);
    font-weight: 700;
    font-size: 1rem;
  }

  /* Progress */
  .progress {
    display: flex;
    align-items: center;
    gap: 0;
    margin-bottom: 3rem;
  }

  .progress-step {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-shrink: 0;
  }

  .step-num {
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-head);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--muted);
    transition: all 0.3s ease;
  }

  .step-label {
    font-family: var(--font-head);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.3s ease;
  }

  .progress-step.active .step-num {
    border-color: var(--gold);
    background: var(--gold);
    color: var(--bg);
  }

  .progress-step.active .step-label { color: var(--cream); }

  .progress-step.done .step-num {
    border-color: var(--gold);
    color: var(--gold);
  }

  .progress-step.done .step-label { color: var(--gold); }

  .progress-line {
    flex: 1;
    height: 1px;
    background: var(--border);
    margin: 0 0.75rem;
  }

  /* Step */
  .step-title {
    font-family: var(--font-head);
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .step-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  /* Barbers */
  .barbers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .barber-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    position: relative;
    padding: 2rem 1rem;
    background: var(--bg-2);
    border: 2px solid var(--border);
    color: var(--cream);
    transition: border-color 0.2s ease, transform 0.2s ease;
    text-align: center;
  }

  .barber-card:hover { border-color: var(--muted); transform: translateY(-2px); }

  .barber-card.selected {
    border-color: var(--gold) !important;
    background: rgba(200, 146, 42, 0.08);
  }

  .barber-card.selected::after {
    content: '✓';
    position: absolute;
    top: 0.5rem;
    right: 0.75rem;
    font-size: 0.75rem;
    color: var(--gold);
    font-weight: 700;
  }

  .barber-avatar {
    width: 4rem;
    height: 4rem;
    border-radius: 50%;
    background: var(--border);
    border: 2px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-head);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--muted);
    transition: border-color 0.2s, color 0.2s;
  }

  .barber-card.selected .barber-avatar {
    border-color: var(--gold);
    color: var(--gold);
  }

  .barber-info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    align-items: center;
  }

  .barber-name {
    font-family: var(--font-head);
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .barber-spec {
    font-size: 0.8rem;
    color: var(--muted);
    font-family: var(--font-head);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-size: 0.7rem;
  }

  .barber-avail {
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border: 1px solid currentColor;
    margin-top: 0.25rem;
  }

  .barber-avail--open { color: var(--gold); }
  .barber-avail--busy { color: var(--gold); }

  /* Calendar */
  .datetime-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: start;
  }

  .calendar-wrap {
    border: 1px solid var(--border);
    background: var(--bg-2);
    padding: 1.5rem;
  }

  .cal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.25rem;
  }

  .cal-month {
    font-family: var(--font-head);
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cream);
  }

  .cal-nav {
    background: none;
    border: 1px solid var(--border);
    color: var(--muted);
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    transition: border-color 0.2s, color 0.2s;
  }

  .cal-nav:hover { border-color: var(--gold); color: var(--gold); }

  .cal-days-header {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
    margin-bottom: 4px;
  }

  .cal-days-header span {
    font-family: var(--font-head);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    text-align: center;
    padding: 0.25rem 0;
  }

  .cal-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 2px;
  }

  .cal-cell {
    aspect-ratio: 1;
    min-height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-head);
    font-size: 0.8rem;
    background: none;
    border: 1px solid transparent;
    color: var(--muted);
    transition: all 0.15s ease;
  }

  .cal-cell--open {
    color: var(--cream);
    border-color: var(--border);
  }

  .cal-cell--open:hover { border-color: var(--gold); color: var(--gold); }

  .cal-cell--closed { color: #333; }

  .cal-cell--blank { border: none; }

  .cal-cell:disabled { cursor: default; }

  .cal-cell.selected {
    background: var(--gold);
    border-color: var(--gold);
    color: var(--bg);
    font-weight: 700;
  }

  /* Slots */
  .slots-wrap {
    border: 1px solid var(--border);
    background: var(--bg-2);
    padding: 1.5rem;
    min-height: 280px;
  }

  .slots-label {
    font-family: var(--font-head);
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 1rem;
  }

  .slots-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
  }

  .slot {
    padding: 0.65rem 0.5rem;
    min-height: 2.75rem;
    border: 1px solid var(--border);
    background: none;
    color: var(--cream);
    font-family: var(--font-head);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
    transition: all 0.15s ease;
  }

  .slot:hover:not(:disabled):not(.selected) { border-color: var(--gold); color: var(--gold); }
  .slot.selected { background: var(--gold); border-color: var(--gold); color: var(--bg); font-weight: 700; box-shadow: 0 0 0 2px var(--gold); }
