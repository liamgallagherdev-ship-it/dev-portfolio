<script>
  (function () {
    const cursor = document.getElementById('pg-cursor');
    if (!cursor) return;
    let cx = 0, cy = 0, tx = 0, ty = 0;
    const tick = () => {
      cx += (tx - cx) / 20;
      cy += (ty - cy) / 20;
      cursor.style.transform = `translate(${Math.round(cx)}px, ${Math.round(cy)}px)`;
      requestAnimationFrame(tick);
    };
    window.addEventListener('mousemove', e => { tx = e.clientX; ty = e.clientY; });
    tick();
  })();

  // Project row preview — scroll-driven sticky section
  (function () {
    const driver        = document.getElementById('projects-driver');
    const preview       = document.getElementById('proj-preview');
    const previewImg    = document.getElementById('proj-preview-img');
    const previewTitle  = document.getElementById('proj-preview-title');
    const previewCta    = document.getElementById('proj-preview-cta');
    const bentoType     = document.getElementById('proj-bento-type');
    const bentoStack    = document.getElementById('proj-bento-stack');
    if (!driver || !preview || !previewImg) return;

    const rows = [...document.querySelectorAll('.proj-row[data-preview]')];
    if (!rows.length) return;

    let currentIdx = -1;

    function setActive(idx) {
      if (idx === currentIdx) return;
      if (currentIdx >= 0) rows[currentIdx].classList.remove('proj-row--active');
      rows[idx].classList.add('proj-row--active');
      const newSrc = rows[idx].dataset.preview;
      const newHref  = rows[idx].getAttribute('href') || '#';
      const newTitle = rows[idx].dataset.overlayTitle || rows[idx].querySelector('.proj-title')?.textContent || '';
      const newCta   = (rows[idx].dataset.cta || 'View Project') + ' →';
      const newType  = rows[idx].dataset.type || '—';
      const stackEls = rows[idx].querySelectorAll('.proj-stack span');
      currentIdx = idx;
      preview.setAttribute('href', newHref);
      if (previewTitle) previewTitle.textContent = newTitle;
      if (previewCta)   previewCta.textContent   = newCta;
      if (bentoType)    bentoType.textContent     = newType;
      if (bentoStack) {
        bentoStack.innerHTML = '';
        stackEls.forEach(el => {
          const tag = document.createElement('span');
          tag.textContent = el.textContent;
          bentoStack.appendChild(tag);
        });
      }
      previewImg.style.opacity = '0';
      setTimeout(() => {
        previewImg.src = newSrc;
        previewImg.style.opacity = '';
      }, 220);
    }

    function update() {
      const rect       = driver.getBoundingClientRect();
      const scrolled   = -rect.top;
      const scrollable = driver.offsetHeight - window.innerHeight;

      // Before section — show first project
      if (scrolled < 0 || scrollable <= 0) {
        setActive(0);
        preview.classList.add('proj-preview--visible');
        return;
      }

      // After section — show last project
      if (scrolled > scrollable) {
        setActive(rows.length - 1);
        preview.classList.add('proj-preview--visible');
        return;
      }

      const progress = scrolled / scrollable;
      const idx = Math.min(rows.length - 1, Math.floor(progress * rows.length));
      setActive(idx);
      preview.classList.add('proj-preview--visible');
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  })();

  // Skills scroll reveal
  (function () {
    const rows = document.querySelectorAll('.skills-row');
    if (!rows.length) return;
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.80 }
    );
    rows.forEach(row => observer.observe(row));
  })();
</script>

<style>
.card-cta {
  font-size: 0.8rem;
  color: var(--color-accent);
  font-weight: 600;
}



  /* ── Hero design tokens ─────────────────────────────────────────── */
  :root {
    --hbg:   #080808;
    --htxt:  #e8e4df;
    --hacc:  #ccff00;
    --hline: rgba(232,228,223,0.09);
    --hmute: rgba(232,228,223,0.42);
    --hfont: 'Bebas Neue', 'Impact', sans-serif;
  }

  /* ── Page background ────────────────────────────────────────────── */
  .page-bg {
    --pbg-bg1: rgb(8, 8, 8);
    --pbg-bg2: rgb(10, 11, 7);
    --pbg-c1: 120, 160, 0;
    --pbg-c2: 60, 90, 0;
    --pbg-c3: 35, 52, 0;
    --pbg-c4: 95, 135, 0;
    --pbg-c5: 14, 20, 2;
    --pbg-ci: 110, 150, 0;
    --pbg-size: 80%;
    --pbg-blend: hard-light;

    position: fixed;
    inset: 0;
    z-index: 0;
    background: linear-gradient(40deg, var(--pbg-bg1), var(--pbg-bg2));
    overflow: hidden;
    filter: blur(50px);
  }

  .page-bg__noise {
    position: absolute;
    width: 100%; height: 100%;
    top: 0; left: 0;
    z-index: 1;
    mix-blend-mode: soft-light;
    opacity: 0.45;
  }

  .page-bg__defs { position: absolute; width: 0; height: 0; overflow: hidden; }

  .page-bg__gradients {
    filter: url(#pg-goo) blur(40px);
    width: 100%; height: 100%;
  }

  .pg1, .pg2, .pg3, .pg4, .pg5, .pg-cursor {
    position: absolute;
    mix-blend-mode: var(--pbg-blend);
  }

  .pg1 {
    background: radial-gradient(circle at center, rgba(var(--pbg-c1), 0.35) 0, rgba(var(--pbg-c1), 0) 50%) no-repeat;
    width: var(--pbg-size); height: var(--pbg-size);
    top: calc(50% - var(--pbg-size) / 2);
    left: calc(50% - var(--pbg-size) / 2);
    transform-origin: center center;
    animation: pgMoveVertical 30s ease infinite;
  }

  .pg2 {
    background: radial-gradient(circle at center, rgba(var(--pbg-c2), 0.35) 0, rgba(var(--pbg-c2), 0) 50%) no-repeat;
    width: var(--pbg-size); height: var(--pbg-size);
    top: calc(50% - var(--pbg-size) / 2);
    left: calc(50% - var(--pbg-size) / 2);
    transform-origin: calc(50% - 400px);
    animation: pgMoveInCircle 20s reverse infinite;
  }

  .pg3 {
    background: radial-gradient(circle at center, rgba(var(--pbg-c3), 0.35) 0, rgba(var(--pbg-c3), 0) 50%) no-repeat;
    width: var(--pbg-size); height: var(--pbg-size);
    top: calc(50% - var(--pbg-size) / 2 + 200px);
    left: calc(50% - var(--pbg-size) / 2 - 500px);
    transform-origin: calc(50% + 400px);
    animation: pgMoveInCircle 40s linear infinite;
  }

  .pg4 {
    background: radial-gradient(circle at center, rgba(var(--pbg-c4), 0.35) 0, rgba(var(--pbg-c4), 0) 50%) no-repeat;
    width: var(--pbg-size); height: var(--pbg-size);
    top: calc(50% - var(--pbg-size) / 2);
    left: calc(50% - var(--pbg-size) / 2);
    transform-origin: calc(50% - 200px);
    animation: pgMoveHorizontal 40s ease infinite;
    opacity: 0.7;
  }

  .pg5 {
    background: radial-gradient(circle at center, rgba(var(--pbg-c5), 0.4) 0, rgba(var(--pbg-c5), 0) 50%) no-repeat;
    width: calc(var(--pbg-size) * 2); height: calc(var(--pbg-size) * 2);
    top: calc(50% - var(--pbg-size));
    left: calc(50% - var(--pbg-size));
    transform-origin: calc(50% - 800px) calc(50% + 200px);
    animation: pgMoveInCircle 20s ease infinite;
  }

  .pg-cursor {
    background: radial-gradient(circle at center, rgba(var(--pbg-ci), 0.28) 0, rgba(var(--pbg-ci), 0) 50%) no-repeat;
    width: 100%; height: 100%;
    top: -50%; left: -50%;
    opacity: 0.22;
  }

  @keyframes pgMoveInCircle {
    0%   { transform: rotate(0deg); }
    50%  { transform: rotate(180deg); }
    100% { transform: rotate(360deg); }
  }
  @keyframes pgMoveVertical {
    0%   { transform: translateY(-50%); }
    50%  { transform: translateY(50%); }
    100% { transform: translateY(-50%); }
  }
  @keyframes pgMoveHorizontal {
    0%   { transform: translateX(-50%) translateY(-10%); }
    50%  { transform: translateX(50%) translateY(10%); }
    100% { transform: translateX(-50%) translateY(-10%); }
  }

  /* ── Hero ───────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    background: linear-gradient(to bottom, #080808 55%, transparent 100%);
    color: var(--htxt);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    padding: 64px 0 0; /* clear fixed nav */
    max-width: none;
    margin: 0;
    border: none;
    align-items: stretch;
    justify-content: flex-start;
  }

  .hero-strip {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.7rem 3rem;
    font-size: 0.6rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--hmute);
    flex-shrink: 0;
    gap: 1rem;
    position: relative;
    z-index: 1;
  }
  .hero-strip--top  { border-bottom: 1px solid var(--hline); }
  .hero-strip--bottom {
    border-top: 1px solid var(--hline);
    margin-top: auto;
    padding: 1.25rem 3rem;
    gap: 2.5rem;
    flex-wrap: wrap;
  }

  .hero-strip__col { display: flex; align-items: center; gap: 0.5rem; }
  .hero-strip__col--center {
    position: absolute;
    left: 50%; transform: translateX(-50%);
  }
  .hero-strip__col--right { margin-left: auto; }

  .hero-sep { color: var(--hacc); }
  .hero-avail {
    color: var(--hacc);
    border: 1px solid var(--hacc);
    padding: 0.2rem 0.65rem;
    font-size: 0.58rem;
    letter-spacing: 0.2em;
  }

  /* Main grid */
  .hero-body {
    flex: 1;
    display: grid;
    grid-template-columns: 1fr;
    padding: 2rem 3rem 1rem;
    gap: 3rem;
    align-items: stretch;
    position: relative;
    z-index: 1;
  }

  .hero-name-block {
    display: flex;
    align-items: flex-end;
    padding-bottom: 1rem;
  }

  .hero-name {
    font-family: var(--hfont);
    font-weight: 900;
    line-height: 0.76;
    text-transform: uppercase;
    color: var(--htxt);
  }
  .hero-name__line {
    display: block;
    font-size: clamp(5rem, 22vw, 28rem);

    color: white;

  }


  /* ── Hero entrance animation ─────────────────────────────────── */
  @keyframes heroRise {
    from { transform: translateY(108%); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }
  @keyframes heroFadeIn {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* curtain container — clips text that starts below */
  .hero-name__line-wrap {
    display: block;
    overflow: hidden;
    padding-bottom: 0.06em;
    margin-bottom: -0.06em;
  }

  .hero-name__line {
    animation: heroRise 1.1s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-name__line--first  { animation-delay: 80ms; }
  .hero-name__line--second { animation-delay: 230ms; }

  .hero-strip--top    { animation: heroFadeIn 0.5s ease both; }
  .hero-strip--bottom { animation: heroFadeIn 0.6s ease both; animation-delay: 600ms; }

  @media (prefers-reduced-motion: reduce) {
    .hero-strip--top, .hero-strip--bottom, .hero-name__line { animation: none; }
  }

  /* Right column: hidden until a real photo is added */
  .hero-right-col {
    display: none;
  }


  .hero-card {
    background: var(--hacc);
    color: var(--hbg);
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0;
    font-family: var(--hfont);
    font-size: 1.2rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    align-self: flex-end;
    z-index: 2;
    position: relative;
  }

  .hero-photo-wrap {
    flex: 1;
    overflow: hidden;
    min-height: 200px;
  }
  .hero-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(1) contrast(1.2) brightness(0.85);
    display: block;
  }

  /* Bottom strip */
  .hero-tagline {
    font-size: 0.78rem;
    line-height: 1.75;
    color: var(--hmute);
    max-width: 300px;
    flex-shrink: 0;
    font-family: var(--font-sans);
  }

  .hero-actions { display: flex; gap: 0.75rem; align-items: center; }

  .hero-btn {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    text-decoration: none;
    padding: 0.65rem 1.5rem;
    background: var(--htxt);
    color: var(--hbg);
    border: 1px solid var(--htxt);
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .hero-btn:hover { background: var(--hacc); border-color: var(--hacc); color: var(--hbg); }
  .hero-btn--outline { background: transparent; color: var(--htxt); }
  .hero-btn--outline:hover { background: var(--htxt); color: var(--hbg); }

  .hero-num {
    margin-left: auto;
    font-family: var(--hfont);
    font-size: 4rem;
    color: rgba(232,228,223,0.05);
    line-height: 1;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
border: 2px solid var(--color-text);
    font-weight: 500;
    font-size: 0.875rem;
    transition: all 0.2s ease;
    color: var(--color-text);
   box-shadow: 10px 10px teal;
max-width:200px;
   justify-self: end;
  }

  .link-btn {
     display: flex;
    align-content: center;
    justify-self: end;

  }

  .link-btn p {
    margin-right: 10px;
  }

  .btn-primary {
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
     box-shadow: 8px 8px teal;
     color: var( --color-text);
  }

    .btn-primary:active {
   box-shadow: 5px 5px teal;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  section {
    padding: 5.5rem 0;
    
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
   padding-bottom: 1.5rem;
   
  }

  /* ── Marquee ticker ────────────────────────────────────────────── */
  @keyframes marqueeScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .marquee {
    overflow: hidden;
    border-top: 1px solid var(--hline);
    border-bottom: 1px solid var(--hline);
    padding: 0.8rem 0;
    background: transparent;
    position: relative;
    z-index: 1;
    white-space: nowrap;
  }

  .marquee__track {
    display: inline-flex;
    animation: marqueeScroll 32s linear infinite;
  }

  .marquee:hover .marquee__track { animation-play-state: paused; }

  .marquee__content {
    display: inline-flex;
    align-items: center;
    gap: 1.75rem;
    padding-right: 1.75rem;
    font-family: 'Courier Prime', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--hmute);
  }

  .mq-sep { color: var(--hacc); }

  @media (prefers-reduced-motion: reduce) {
    .marquee__track { animation: none; }
  }

  /* ── About ──────────────────────────────────────────────────────── */
  .about {
    background: transparent;
    color: var(--htxt);
    position: relative;
    z-index: 1;
    padding: 0;
    margin: 0;
    border: none;
  }

  .about-eyebrow {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.8rem 3rem;
    border-top: 1px solid var(--hline);
    border-bottom: 1px solid var(--hline);
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
