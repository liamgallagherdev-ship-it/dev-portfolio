  .proj-group__label {
    font-family: var(--hfont);
    font-size: 0.9rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--hacc);
    flex-shrink: 0;
  }

  .proj-group__desc {
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--hmute);
  }

  .proj-row {
    display: grid;
    grid-template-columns: 3.5rem 1fr;
    grid-template-rows: auto auto;
    align-items: start;
    gap: 0.4rem 2rem;
    padding: 1.75rem 0;
