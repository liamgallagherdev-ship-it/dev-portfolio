  .proj-num {
    font-family: var(--hfont);
    font-size: 1.1rem;
    color: var(--hacc);
    letter-spacing: 0.08em;
    flex-shrink: 0;
    grid-row: 1;
    padding-top: 0.3em;
  }

  .proj-info { grid-column: 2; grid-row: 1; min-width: 0; }

  .proj-title {
    font-family: var(--hfont);
    font-size: clamp(1.5rem, 2.5vw, 2.5rem);
    line-height: 1;
    text-transform: uppercase;
    color: var(--htxt);
    margin-bottom: 0.4rem;
    transition: color 0.2s;
  }

  .proj-row--active .proj-title,
  .proj-row:hover   .proj-title { color: var(--hacc); }

  .proj-stack {
    grid-column: 2;
    grid-row: 2;
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
   
  }

  .proj-stack span {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--hmute);
    border: 1px solid var(--hline);
    padding: 0.3rem 0.65rem;
  }


  @media (max-width: 768px) {
