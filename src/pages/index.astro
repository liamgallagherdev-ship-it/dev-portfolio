  /* Tall container that creates scroll distance for the pinned stage */
  .projects-driver {
    position: relative;
    height: calc(5 * 12vh + 100vh);
  }

  /* Sticky stage: pins to viewport while user scrolls through driver */
  .projects-inner {
    position: sticky;
    top: 64px;
    height: calc(100vh);
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 10rem;
    padding: 3rem 4rem;
    align-items: start;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0,0,0,1) 50%, rgba(0, 0, 0, 0) 100%);
  }

  .projects-content {
    grid-column: 1;
    display: flex;
