    letter-spacing: 0.08em;
    flex-shrink: 0;
  }

  .about-eyebrow__line {
    flex: 1;
    height: 1px;
    background: var(--hline);
  }

  .about-inner {
    display: grid;
    grid-template-columns: 1fr 0.3fr 1fr;
    gap: 5rem;
    padding: 5rem 3rem 6rem;
    align-items: start;
  }

  .about-headline {
    font-family: var(--hfont);
    font-size: clamp(3rem, 6vw, 7.5rem);
    line-height: 0.92;
    text-transform: uppercase;
    color: var(--htxt);
    margin-bottom: 2.5rem;
  }

  .about-body {
    font-family: var(--font-sans);
    font-size: 0.875rem;
    line-height: 1.9;
    color: var(--hmute);
    max-width: 520px;
  }

  .about-aside {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-top: 0.5rem;
  }

  .about-aside__item {
    border-top: 1px solid var(--hline);
    padding: 1.25rem 0;
  }

  .about-aside__value {
    display: block;
    font-family: var(--hfont);
    font-size: 2.75rem;
    color: var(--hacc);
    line-height: 1;
    letter-spacing: 0.04em;
    margin-bottom: 0.3rem;
  }

  .about-aside__label {
    font-family: var(--font-sans);
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--hmute);
  }

  .about-aside__item--avail .about-aside__dot {
    display: inline-block;
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--hacc);
    margin-right: 0.6rem;
    vertical-align: middle;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.75); }
  }

  @media (max-width: 768px) {
    .about-eyebrow { padding: 0.8rem 1.5rem; }
    .about-inner {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem 4rem;
      gap: 3rem;
    }
    .about-aside {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0;
      border-top: 1px solid var(--hline);
    }
    .about-aside__item {
      border-top: none;
      border-bottom: 1px solid var(--hline);
      border-right: 1px solid var(--hline);
      padding: 1.25rem 1rem;
    }
    .about-aside__item:nth-child(even) { border-right: none; }
  }

  /* ── Skills ─────────────────────────────────────────────────────── */
  .skills {
    background: transparent;
    color: var(--htxt);
    position: relative;
    z-index: 1;
    padding: 0;
    margin: 0;
    border: none;
  }

  .skills-eyebrow {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.8rem 3rem;
    border-top: 1px solid var(--hline);
    border-bottom: 1px solid var(--hline);
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--hmute);
  }

  .skills-idx {
    font-family: var(--hfont);
  font-size: 3rem;
    color: var(--hacc);
    letter-spacing: 0.08em;
    flex-shrink: 0;
  }

  .skills-eyebrow__line {
    flex: 1;
    height: 1px;
    background: var(--hline);
  }

  .skills-inner {
    display: grid;
    grid-template-columns: 1fr 0.3fr 1fr;
    gap: 5rem;
    padding: 5rem 3rem 6rem;
    align-items: start;
  }

  .skills-table {
    grid-column: 2 / -1;
    padding: 0;
  }

  .skills-row {
    padding: 1.75rem 0;
    border-bottom: 1px solid var(--hline);
  }
  .skills-row:first-child { border-top: 1px solid var(--hline); }

  .skills-row__header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .skills-row__line {
    flex: 1;
    height: 1px;
    background: var(--hline);
  }

  .skills-row__cat {
    font-family: 'Courier Prime', monospace;
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--hacc);
    white-space: nowrap;
  }

  .skills-row__stack {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    font-family: var(--hfont);
    font-size: clamp(2.2rem, 4.5vw, 5.5rem);
    line-height: 0.95;
    text-transform: uppercase;
    color: var(--htxt);
    letter-spacing: 0.02em;
    padding-top: 0.25rem;
  }
  .skills-row__stack--start { align-items: flex-start; }

  .sd { color: var(--hacc); margin: 0 0.1em; }

  /* ── Skills scroll reveal ───────────────────────────────────────── */
  .skills-row__header .skills-row__line,
  .skills-row__header .skills-row__cat {
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .skills-row__stack span {
    color: rgba(232, 228, 223, 0.14);
    transition: color 0.55s ease;
  }

  /* triggered by JS when row enters viewport */
  .skills-row.is-visible .skills-row__line,
  .skills-row.is-visible .skills-row__cat { opacity: 1; }

  .skills-row.is-visible .skills-row__stack span { color: var(--htxt); }

  .skills-row.is-visible .skills-row__stack span:nth-child(1) { transition-delay: 0.05s; }
  .skills-row.is-visible .skills-row__stack span:nth-child(2) { transition-delay: 0.12s; }
  .skills-row.is-visible .skills-row__stack span:nth-child(3) { transition-delay: 0.19s; }
  .skills-row.is-visible .skills-row__stack span:nth-child(4) { transition-delay: 0.26s; }
  .skills-row.is-visible .skills-row__stack span:nth-child(5) { transition-delay: 0.33s; }
  .skills-row.is-visible .skills-row__stack span:nth-child(6) { transition-delay: 0.40s; }
  .skills-row.is-visible .skills-row__stack span:nth-child(7) { transition-delay: 0.47s; }

  @media (max-width: 768px) {
    .skills-eyebrow { padding: 0.8rem 1.5rem; }
    .skills-inner { grid-template-columns: 1fr; padding: 2rem 1.5rem 3rem; gap: 0; }
    .skills-table { grid-column: 1; }
    .skills-row { padding: 1.25rem 0; }
    .skills-row__stack { font-size: clamp(1.6rem, 7vw, 2.5rem); }
  }



  /* ── Projects ───────────────────────────────────────────────────── */
  .projects {
    background: transparent;
    color: var(--htxt);
    position: relative;
    z-index: 1;
    padding: 0;
    margin: 0;
    border: none;
  }

  .projects-eyebrow {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 0.8rem 3rem;
    border-top: 1px solid var(--hline);
    border-bottom: 1px solid var(--hline);
    font-family: var(--font-sans);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
