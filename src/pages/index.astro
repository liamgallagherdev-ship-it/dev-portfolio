
---
import BaseLayout from '../layouts/BaseLayout.astro';
import LinkButton from '../components/LinkButton.vue';
import TypeWriter from '../components/TypeWriter.vue';
import AntText1 from '../components/Playground/AntText copy.vue';
---

<BaseLayout title="Frontend Developer Portfolio">
  <!-- Hero Section -->
  <section class="hero">

    <div class="hero-content">
    <div>
      <p class="greeting ">Hi, I’m Liam</p>
    <h1 class="header"> 
   
    <AntText1 class="writing"  client:load />



    <div> Frontend Developer </div></h1>
      <p class="tagline">I build fast, intuitive interfaces with a focus on performance, usability, and detail.</p>
      <div class="hero-cta">
        <a href="#projects" class="btn btn-primary">View My Work</a>
        <LinkButton url="#contact" label="Get In Touch" />
</div>
           
      </div>
        <img class="avatar" src="/images/logos/Avatar-c.png" alt="Figma Project" width="50" height="50" />
    </div>
  </section>

  <!-- About Section -->
 
  <section id="about" class="about">
    <div class="container">
      <h2 class="section-title bungee-shade-regular">About Me</h2>
      <div class="about-content">
        <p>
          I'm a passionate frontend developer with a keen eye for design and a love for creating 
          seamless user experiences. With expertise in modern JavaScript frameworks and a 
          strong foundation in web technologies, I build responsive, accessible, and performant 
          web applications.
        </p>
      </div>
    </div>
  </section>

 <div class="skills-projects">
  <!-- Skills Section -->
  <section id="skills" class="skills">
    <div class="container">
      <h2 class="section-title bungee-shade-regular">Skills & Technologies</h2>
      <div class="skills-grid">
        <div class="skill-card">
          <h3>Frontend</h3>
          <ul>
            <li>React / Vue</li>
            <li>TypeScript</li>
            <li>HTML5 / CSS3</li>
            <li>Tailwind CSS</li>
          </ul>
        </div>
        <div class="skill-card">
          <h3>Tools & DevOps</h3>
          <ul>
            <li>Git / GitHub</li>
            <li>VS Code</li>
            <li>Chrome DevTools</li>
            <li>npm / yarn</li>
          </ul>
        </div>
        <div class="skill-card">
          <h3>Design</h3>
          <ul>
            <li>Figma</li>
            <li>UI/UX Principles</li>
            <li>Responsive Design</li>
            <li>Accessibility</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
 

  <!-- Projects Section -->
  <section id="projects" class="projects">
    <div class="container">
      <h2 class="section-title bungee-shade-regular">Featured Projects</h2>
      <div class="projects-grid">
        <article class="project-card">
        <div>
          <h3>Win Sporting Prizes</h3>
          <p>A gamified sports rewards platform built to increase engagement and diversify revenue.</p>
              </div>
          <div class="project-tags">
            <img class="logos" src="/images/logos/FigmaSvg50x50.svg" alt="Figma Project" width="50" height="50" />
            <img class="logos" src="/images/logos/VueSvg50x50.svg" alt="Figma Project" width="50" height="50" />
            <img class="logos" src="/images/logos/FigmaSvg50x50.svg" alt="Figma Project" width="50" height="50" />
            <img class="logos" src="/images/logos/VueSvg50x50.svg" alt="Figma Project" width="50" height="50" />
            <img class="logos" src="/images/logos/VueSvg50x50.svg" alt="Figma Project" width="50" height="50" />
          </div>
               <LinkButton url="/winsportingprizes" label="View Case Study" />

        </article>
        <article class="project-card">
          <h3>Rewards4 Platform</h3>
          <p>Modernising a multi-brand rewards ecosystem with Vue 3, TypeScript, and improved UX.</p>
          <div class="project-tags">
            <img class="logos" src="/images/logos/VueSvg50x50.svg" alt="Vue Project" width="50" height="50" />
            <img class="logos" src="/images/logos/VueSvg50x50.svg" alt="Vue Project" width="50" height="50" />
            <img class="logos" src="/images/logos/VueSvg50x50.svg" alt="Vue Project" width="50" height="50" />
            <img class="logos" src="/images/logos/VueSvg50x50.svg" alt="Vue Project" width="50" height="50" />
            <img class="logos" src="/images/logos/VueSvg50x50.svg" alt="Vue Project" width="50" height="50" />
          </div>
          <LinkButton url="/rewards4" label="View Case Study" />
        </article>
        <article class="project-card">
          <h3>Project Three</h3>
          <p>A brief description of the project and the technologies used.</p>
          <div class="project-tags">
             <img class="logos" src="/images/logos/FigmaSvg50x50.svg" alt="Figma Project" width="50" height="50" />
                           <img class="logos" src="/images/logos/VueSvg50x50.svg" alt="Figma Project" width="50" height="50" />
                          <img class="logos" src="/images/logos/FigmaSvg50x50.svg" alt="Figma Project" width="50" height="50" />
                           <img class="logos" src="/images/logos/VueSvg50x50.svg" alt="Figma Project" width="50" height="50" />
                               <img class="logos" src="/images/logos/VueSvg50x50.svg" alt="Figma Project" width="50" height="50" />
          </div>
              <LinkButton url="/winsportingprizes" label="View Case Study" />
        </article>
   
      </div>
    </div>
  </section>
  </div>

  <!-- Contact Section -->
  <section id="contact" class="contact">
    <div class="container">
      <h2 class="section-title">Get In Touch</h2>
      <p class="contact-text">
        I'm always open to discussing new projects, creative ideas, or opportunities to be part of your visions.
      </p>
      <a href="mailto:your.email@example.com" class="btn btn-primary">Send Me an Email</a>
    </div>
    
  </section>
</BaseLayout>

<style>

.writing {
  max-width: 300px;
}

  .hero {
      position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 4rem 4rem;
    border-inline: 2px solid var(--color-border);
    max-width: 1250px;
    margin-inline: auto;
  }

  .avatar {
      width: 400px;
    height: 100%;
    opacity: 0.75;
    aspect-ratio: 2 / 2;
  }

  .hero-content {
      position: relative;
    display: grid;
    grid-template-columns: 1.5fr 1fr;
  }

  @media(max-width: 850px) {
      .hero-content {
    grid-template-columns: 1fr;
  }
 .avatar {
  position: absolute;
    width: 400px;
     height: 400px;
  aspect-ratio: 2/2;
  z-index: -1;
  bottom:0;
  right:0;
      opacity: 0.2;
  }

  }

  .greeting {
    font-size: 1.125rem;
    color: var(--color-text);
  padding-left: 6px;
  
  }

  .header {
    display:grid;
    font-size: 4rem;
    line-height: 0.9;
    text-transform: uppercase;
    font-weight: 700;
    margin-bottom: 1rem;
   -webkit-text-fill-color: var(--color-accent-muted);
    -webkit-text-stroke-width: 1px;
    word-spacing: -30px;
  }


  .tagline {
    font-size: 1.25rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    max-width: 500px;
   
  }

  .hero-cta {
    display: grid;
       grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 2rem;
    justify-content: center;
    align-items: end;
  }

  .btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
border: 2px solid var(--color-text);
    font-weight: 500;
    font-size: 0.875rem;
    transition: all 0.2s ease;
    color: var(--color-text);
   box-shadow: 10px 10px teal;
max-width:200px;
   justify-self: end;
  }

  .link-btn {
     display: flex;
    align-content: center;.
    justify-self: end;

  }

  .link-btn p {
    margin-right: 10px;
  }

  .btn-primary {
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
     box-shadow: 8px 8px teal;
  }

    .btn-primary:active {
   box-shadow: 5px 5px teal;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  section {
    padding: 6rem 0;
    
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
   padding-bottom: 1.5rem;
   
  }

  .about {
    border-block: 3px solid var(--color-border);
    margin-top: -50px;
  }

  /* About Section */
  .about-content {
    max-width: 700px;
    margin: 0 auto;
    text-align: center;
    
  }

  .about-content p {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

.skills-projects {
    border-inline: 2px solid var(--color-border);
    margin-top: -50px;
      max-width: 1250px;
      margin-inline: auto;
  }


  /* Skills Section */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .skill-card {
    border: 3px dashed;
    box-shadow: 6px 6px 0;
    padding: 1.5rem;
  }

  .skill-card:nth-child(1) { transform: rotate(-2.5deg); }
  .skill-card:nth-child(2) { transform: rotate(0deg); margin-top: 10px; }
  .skill-card:nth-child(3) { transform: rotate(2.5deg); }

  .skill-card h3 {
    font-size: 1.125rem;
    margin-bottom: 1rem;
    color: var(--color-accent);
  }

  .skill-card ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .skill-card li {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }



  /* Projects Section */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
       
  }

  .project-card {
  
padding: 1.5rem 1.5rem 1rem 1.5rem;
    transition: transform 0.2s ease;
    border: 3px dashed;
    box-shadow: 6px 6px 0;
    display: grid;
    gap: 1rem;

  }


  .project-card:hover {
   transition: a
  }


 .project-card .logos {
  filter: grayscale(0.6);
  transform: scale(1);
}

.project-card:hover .logos {
  animation: colorScale 0.4s forwards;
}

.project-card .logos:nth-child(1) { animation-delay: 0s; }
.project-card .logos:nth-child(2) { animation-delay: 0.1s; }
.project-card .logos:nth-child(3) { animation-delay: 0.2s; }
.project-card .logos:nth-child(4) { animation-delay: 0.3s; }
.project-card .logos:nth-child(5) { animation-delay: 0.4s; }

@keyframes colorScale {
  0% { 
    filter: grayscale(1);
    transform: scale(1);
  }
  50% { 
    filter: grayscale(0);
    transform: scale(1.1);
  }
  100% { 
    filter: grayscale(0);
    transform: scale(1);
  }
}

 

  .project-card h3 {
    font-size: 1.5rem;
    
  }

  .project-card p {
    color: var(--color-text-muted);
    font-size: 0.875rem;

  }

  .project-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .project-tags span {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    padding: 0.25rem 0.75rem;
    border-radius: 1rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  /* Contact Section */
  .contact {
    text-align: center;
    border-block: 1px solid var(--color-border);
    margin-top: -50px;
    
  }

  .contact-text {
    color: var(--color-text-muted);
    max-width: 500px;
    margin: 0 auto 2rem;
  }

  @media (max-width: 768px) {
    .name {
      font-size: 2.5rem;
    }

    .hero-cta {
      flex-direction: column;
    }

    .btn {
      width: 100%;
      text-align: center;
    }

      .header {
    
        word-spacing: -20px;
  }
  .header {
 
    font-size: 50px;

  }


  .hero {
  padding: 1rem;
}
 .section-title {
    font-size: 1.5rem;

   
  }

  .writing {
  max-width: 150px;
}
  }



  

  
</style>