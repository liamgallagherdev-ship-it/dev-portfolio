    </div>

    <!-- bottom strip: tagline + CTAs -->
    <div class="hero-strip hero-strip--bottom">
      <p class="hero-tagline">I build thoughtful digital experiences —<br>fast, intuitive, and effortless to use.</p>
      <div class="hero-actions">
        <a href="#projects" class="hero-btn">View Work →</a>
        <a href="#contact" class="hero-btn hero-btn--outline">Get in Touch</a>
      </div>
